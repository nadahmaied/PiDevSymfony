{% extends 'baseFront.html.twig' %}
{% set poso = ordonnance.posologie|default('') %}
{% set isAiOrdonnance = 'IA' in poso or 'auto' in poso|lower %}

{% block title %}
<h1 class="text-2xl font-black text-gray-800 tracking-tight">Prescription Médicale 💊</h1>
{% endblock %}

{% block body %}
<div class="px-8 py-8 space-y-10">
    <div class="flex items-center justify-between">
        <a href="{{ path('patient_dossier') }}" class="flex items-center gap-2 text-gray-400 hover:text-indigo-600 transition-all font-black group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Retour au dossier
        </a>
        <div class="flex items-center gap-4">
            <span class="px-4 py-2 rounded-xl text-xs font-black uppercase {{ isAiOrdonnance ? 'bg-indigo-100 text-indigo-700' : 'bg-amber-100 text-amber-700' }}">
                {{ isAiOrdonnance ? 'Suggestion IA' : 'Ordonnance Médecin' }}
            </span>
            <button onclick="window.print()" class="px-6 py-3 {{ isAiOrdonnance ? 'bg-indigo-50 text-indigo-600 hover:bg-indigo-600' : 'bg-amber-50 text-amber-600 hover:bg-amber-600' }} rounded-2xl font-black text-xs hover:text-white transition-all flex items-center gap-2">
                <i class="fa-solid fa-print"></i> Imprimer
            </button>
        </div>
    </div>

    {% if qrDataUri is defined and qrDataUri %}
    <div class="bg-white rounded-3xl shadow-xl p-8 border border-slate-100 text-center max-w-xs mx-auto">
        <p class="text-slate-500 text-xs font-black uppercase tracking-widest mb-2">Digital Prescription Scan</p>
        <p class="text-slate-400 text-sm font-medium mb-4">Scannez pour accéder à la prescription sur mobile</p>
        <div class="inline-flex p-3 bg-slate-50 rounded-2xl border border-slate-100">
            <img src="{{ qrDataUri }}" alt="QR Code prescription" class="w-40 h-40" width="160" height="160">
        </div>
    </div>
    {% endif %}

    {% if isAiOrdonnance %}
    {# === INTERFACE IA (tech/digital style) === #}
    <div class="bg-white rounded-[3rem] shadow-2xl shadow-indigo-100 border-2 border-indigo-200 p-0 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-96 h-96 bg-indigo-100/50 rounded-full blur-3xl -mr-48 -mt-48 pointer-events-none"></div>
        <div class="grid grid-cols-1 lg:grid-cols-5">
            <div class="lg:col-span-2 bg-gradient-to-br from-indigo-700 to-purple-800 p-12 text-white flex flex-col justify-between relative overflow-hidden">
                <div class="relative z-10">
                    <div class="w-20 h-20 bg-white/20 backdrop-blur-md rounded-3xl flex items-center justify-center text-4xl mb-10">
                        <i class="fa-solid fa-microchip"></i>
                    </div>
                    <h2 class="text-xs font-black text-indigo-200 uppercase tracking-widest mb-2">Suggestion IA</h2>
                    <h3 class="text-3xl font-black italic mb-10">Récapitulatif généré par l'IA.</h3>
                    <div class="space-y-8">
                        <div>
                            <p class="text-[10px] font-black text-indigo-300 uppercase tracking-widest mb-2">Durée</p>
                            <div class="inline-flex items-center gap-3 px-6 py-4 bg-white/10 rounded-2xl border border-white/20">
                                <i class="fa-solid fa-clock text-xl"></i>
                                <p class="text-2xl font-black">{{ ordonnance.dureeTraitement }} <small class="text-xs opacity-60">Jours</small></p>
                            </div>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-indigo-300 uppercase tracking-widest mb-2">Fréquence</p>
                            <p class="text-lg font-bold italic">{{ ordonnance.frequence }}</p>
                        </div>
                    </div>
                </div>
                <div class="relative z-10 pt-16 mt-16 border-t border-white/10">
                    <p class="text-[10px] font-black text-indigo-300 uppercase tracking-widest">Validation médicale requise</p>
                    <p class="font-bold text-sm mt-1">À faire valider par un médecin avant usage.</p>
                </div>
                <i class="fa-solid fa-robot absolute -right-10 top-1/2 text-[12rem] text-white/5 pointer-events-none"></i>
            </div>
            <div class="lg:col-span-3 p-12 space-y-10 bg-white relative">
                <div class="flex items-center justify-between border-b border-indigo-50 pb-8">
                    <h4 class="text-2xl font-black text-gray-800 flex items-center gap-3">
                        <i class="fa-solid fa-pills text-indigo-600"></i>
                        Médicaments suggérés
                    </h4>
                    <span class="bg-indigo-100 text-indigo-700 px-4 py-1 rounded-xl text-xs font-black uppercase">{{ ordonnance.medicaments|length }} Items</span>
                </div>
                <div class="space-y-8">
                    <div>
                        <p class="text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] mb-4">Indications</p>
                        <div class="p-8 bg-indigo-50 rounded-[2.5rem] border border-indigo-100 font-bold text-indigo-800 italic text-lg">
                            "{{ ordonnance.posologie }}"
                        </div>
                    </div>
                    <div class="space-y-4">
                        <p class="text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em] mb-4">Spécialités</p>
                        {% for medicament in ordonnance.medicaments %}
                            <div class="flex items-center justify-between p-6 bg-indigo-50/50 rounded-2xl border border-indigo-100 hover:border-indigo-200 transition-all group">
                                <div class="flex items-center gap-5">
                                    <div class="w-14 h-14 bg-indigo-100 rounded-2xl flex items-center justify-center text-indigo-600">
                                        <i class="fa-solid fa-capsules text-2xl"></i>
                                    </div>
                                    <div>
                                        <h5 class="font-black text-gray-800 text-lg italic">"{{ medicament.nomMedicament }}"</h5>
                                        <p class="text-xs font-bold text-indigo-600 uppercase">{{ medicament.dosage }} • {{ medicament.forme }}</p>
                                    </div>
                                </div>
                                <a href="{{ path('patient_medicaments', {search: medicament.nomMedicament}) }}" class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-400 hover:text-indigo-600 transition-all">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>
                            </div>
                        {% else %}
                            <p class="text-gray-400 font-bold italic text-center py-10">Aucun médicament spécifié.</p>
                        {% endfor %}
                    </div>
                </div>
                <div class="bg-indigo-900 text-white rounded-3xl p-6 flex gap-4 mt-12">
                    <i class="fa-solid fa-triangle-exclamation text-indigo-300 text-xl mt-1"></i>
                    <div>
                        <p class="text-xs font-black text-indigo-200 uppercase mb-1">Validation obligatoire</p>
                        <p class="text-sm text-indigo-100 font-medium">Cette suggestion IA doit être validée par un médecin avant présentation en pharmacie.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    {# === INTERFACE MÉDECIN (clinical/official style) === #}
    <div class="bg-white rounded-[3rem] shadow-2xl shadow-amber-100/50 border-2 border-amber-200 p-0 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-96 h-96 bg-amber-50 rounded-full blur-3xl -mr-48 -mt-48 pointer-events-none"></div>
        <div class="grid grid-cols-1 lg:grid-cols-5">
            <div class="lg:col-span-2 bg-gradient-to-br from-amber-600 to-amber-800 p-12 text-white flex flex-col justify-between relative overflow-hidden">
                <div class="relative z-10">
                    <div class="w-20 h-20 bg-white/20 backdrop-blur-md rounded-3xl flex items-center justify-center text-4xl mb-10">
                        <i class="fa-solid fa-briefcase-medical"></i>
                    </div>
                    <h2 class="text-xs font-black text-amber-200 uppercase tracking-widest mb-2">Ordonnance Officielle</h2>
                    <h3 class="text-4xl font-black italic mb-10">Récapitulatif de votre traitement.</h3>
                    <div class="space-y-8">
                        <div>
                            <p class="text-[10px] font-black text-amber-300 uppercase tracking-widest mb-2">Durée prescrite</p>
                            <div class="inline-flex items-center gap-3 px-6 py-4 bg-white/10 rounded-2xl border border-white/10">
                                <i class="fa-solid fa-hourglass-half text-xl"></i>
                                <p class="text-2xl font-black tracking-tight">{{ ordonnance.dureeTraitement }} <small class="text-xs opacity-60">Jours</small></p>
                            </div>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-amber-300 uppercase tracking-widest mb-2">Fréquence des prises</p>
                            <p class="text-lg font-bold italic">{{ ordonnance.frequence }}</p>
                        </div>
                    </div>
                </div>
                <div class="relative z-10 pt-16 mt-16 border-t border-white/10">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center">
                            <i class="fa-solid fa-user-doctor text-xl"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-amber-300 uppercase tracking-widest">Prescrit par</p>
                            <p class="font-black text-lg">{{ ordonnance.idU.email|split('@')|first|capitalize }}</p>
                        </div>
                    </div>
                </div>
                <i class="fa-solid fa-heart-pulse absolute -right-10 top-1/2 text-[15rem] text-white/5 pointer-events-none"></i>
            </div>
            <div class="lg:col-span-3 p-12 space-y-10 bg-white relative">
                <div class="flex items-center justify-between border-b border-amber-50 pb-8">
                    <h4 class="text-2xl font-black text-gray-800 flex items-center gap-3">
                        <i class="fa-solid fa-pills text-amber-600"></i>
                        Médicaments à prendre
                    </h4>
                    <span class="bg-amber-100 text-amber-700 px-4 py-1 rounded-xl text-xs font-black uppercase">{{ ordonnance.medicaments|length }} Items</span>
                </div>
                <div class="space-y-8">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4 pl-1">Indications Posologiques</p>
                        <div class="p-8 bg-amber-50 rounded-[2.5rem] border border-amber-100 font-bold text-amber-900 italic leading-relaxed text-lg">
                            "{{ ordonnance.posologie }}"
                        </div>
                    </div>
                    <div class="space-y-4">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4 pl-1">Détails des spécialités</p>
                        {% for medicament in ordonnance.medicaments %}
                            <div class="flex items-center justify-between p-6 bg-white rounded-3xl border border-amber-100 shadow-sm hover:shadow-xl hover:border-amber-200 transition-all group">
                                <div class="flex items-center gap-5">
                                    <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600 group-hover:scale-110 transition-transform">
                                        <i class="fa-solid fa-capsules text-2xl"></i>
                                    </div>
                                    <div>
                                        <h5 class="font-black text-gray-700 text-lg group-hover:text-amber-700 transition-colors italic">"{{ medicament.nomMedicament }}"</h5>
                                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">{{ medicament.dosage }} • {{ medicament.forme }}</p>
                                    </div>
                                </div>
                                <a href="{{ path('patient_medicaments', {search: medicament.nomMedicament}) }}" class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-gray-300 hover:text-amber-500 hover:bg-amber-50 transition-all">
                                    <i class="fa-solid fa-circle-info"></i>
                                </a>
                            </div>
                        {% else %}
                            <p class="text-gray-400 font-bold italic text-center py-10">Aucun détail de médicament spécifique.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
