{% extends 'baseFront.html.twig' %}

{% block title %}
<h1 class="text-2xl font-black text-gray-800 tracking-tight">Analyse Clinique #{{ fiche.id }} 📋</h1>
{% endblock %}

{% block body %}
<div class="px-8 py-8">
    <!-- Back Header -->
    <div class="flex items-center justify-between mb-8">
        <a href="{{ path('patient_dossier') }}" class="flex items-center gap-2 text-gray-400 hover:text-blue-600 transition-all font-black group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Retour au dossier
        </a>
        <div class="flex items-center gap-4">
            <span class="px-5 py-2 rounded-2xl bg-emerald-100 text-emerald-700 text-xs font-black uppercase tracking-widest border border-emerald-200">
                Diagnostic Validé
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- LEFT COLUMN: Patient Info & Ordonnances (4/12) -->
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-white rounded-[2rem] shadow-xl shadow-gray-200/50 p-8 border border-gray-100">
                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Signes Vitaux</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase block mb-1">Poids</span>
                        <span class="text-lg font-black text-slate-700">{{ fiche.poids }} <small class="text-[10px] opacity-30">kg</small></span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase block mb-1">Taille</span>
                        <span class="text-lg font-black text-slate-700">{{ fiche.taille }} <small class="text-[10px] opacity-30">cm</small></span>
                    </div>
                    <div class="p-4 bg-red-50/50 rounded-2xl border border-red-100">
                        <span class="text-[10px] font-black text-red-400 uppercase block mb-1">Groupe</span>
                        <span class="text-lg font-black text-red-600">{{ fiche.grpSanguin }}</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <span class="text-[10px] font-black text-slate-400 uppercase block mb-1">Tension</span>
                        <span class="text-lg font-black text-slate-700">{{ fiche.tension }}</span>
                    </div>
                </div>
            </div>

            <!-- AI ORDONNANCES (tech/digital style) -->
            <div class="bg-indigo-900 rounded-[2rem] p-8 text-white shadow-2xl relative overflow-hidden group">
                <h3 class="text-lg font-black mb-6 flex items-center gap-3 relative z-10">
                    <i class="fa-solid fa-robot text-indigo-400"></i>
                    Mes Ordonnances IA
                </h3>
                <div class="space-y-3 relative z-10">
                    {% for ord in aiOrdonnances %}
                        <a href="{{ path('patient_ordonnance_show', {'id': ord.id}) }}" class="block p-4 bg-white/10 rounded-xl border border-indigo-400/30 hover:bg-white/20 transition-all border-l-4 border-l-indigo-400">
                            <div class="flex justify-between items-start mb-1">
                                <span class="font-bold text-xs">{{ ord.dateOrdonnance|date('d/m/Y') }}</span>
                                <span class="px-2 py-0.5 bg-indigo-500/50 rounded text-[10px] font-bold">IA</span>
                            </div>
                            <p class="text-[10px] text-indigo-200 line-clamp-1 italic">{{ ord.frequence }}</p>
                        </a>
                    {% else %}
                        <p class="text-indigo-300 text-xs italic text-center py-4">Aucune ordonnance IA pour le moment.</p>
                    {% endfor %}
                </div>
                <i class="fa-solid fa-microchip absolute -right-4 -bottom-4 text-white/5 text-7xl opacity-50"></i>
            </div>

            <!-- DOCTOR ORDONNANCES (clinical/official style) -->
            <div class="bg-amber-50 rounded-[2rem] p-8 border-2 border-amber-200 shadow-xl shadow-amber-100/50">
                <h3 class="text-lg font-black text-amber-800 mb-6 flex items-center gap-3">
                    <i class="fa-solid fa-stethoscope text-amber-600"></i>
                    Ordonnances Docteur
                </h3>
                <div class="space-y-3">
                    {% for ord in docOrdonnances %}
                        <a href="{{ path('patient_ordonnance_show', {'id': ord.id}) }}" class="block p-4 bg-white rounded-lg border-l-4 border-l-amber-500 border border-amber-100 hover:border-amber-300 hover:shadow-md transition-all">
                            <div class="flex justify-between items-start mb-1">
                                <span class="font-bold text-amber-800 text-xs">{{ ord.dateOrdonnance|date('d/m/Y') }}</span>
                                <span class="px-2 py-0.5 bg-amber-200 text-amber-800 rounded text-[10px] font-bold">Médecin</span>
                            </div>
                            <p class="text-[10px] text-amber-700 line-clamp-1">{{ ord.frequence }}</p>
                        </a>
                    {% else %}
                        <p class="text-amber-600 text-xs italic text-center py-4">Aucune ordonnance directe.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Diagnostic & AI Suggestion (8/12) -->
        <div class="lg:col-span-8 space-y-6">
            <div class="bg-white rounded-[2rem] shadow-xl shadow-gray-200/50 p-10 border border-gray-100 relative">
                <div class="absolute top-0 right-0 w-48 h-48 bg-emerald-50 rounded-full blur-3xl opacity-50"></div>
                <div class="flex items-center justify-between mb-8 relative z-10">
                    <h2 class="text-xl font-black text-gray-800 flex items-center gap-3">
                        <i class="fa-solid fa-stethoscope text-indigo-500"></i>
                        Diagnostic Médical
                    </h2>
                    <span class="px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest
                        {% if fiche.gravite == 'Élevée' %}bg-red-100 text-red-600{% else %}bg-emerald-100 text-emerald-600{% endif %}">
                        {{ fiche.gravite }}
                    </span>
                </div>
                
                <h3 class="text-3xl font-black text-gray-700 mb-8 italic relative z-10">"{{ fiche.libelleMaladie }}"</h3>
                
                <div class="pt-8 border-t border-slate-100 relative z-10">
                    <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Recommandation du Médecin</h4>
                    <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 text-base font-bold text-slate-600 leading-relaxed italic">
                        {{ fiche.recommandation|default('Consultation de suivi recommandée.') }}
                    </div>
                </div>
            </div>

            <!-- AI RECOMMENDATION CENTER -->
            <div class="bg-indigo-50 border border-indigo-100 rounded-[2rem] p-10">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-8">
                    <div>
                        <h3 class="text-xl font-black text-indigo-900 flex items-center gap-3">
                            <i class="fa-solid fa-robot"></i>
                            Assistant Thérapeutique IA
                        </h3>
                        <p class="text-indigo-600/70 font-bold text-xs mt-1">Analyse intelligente via OpenAI v4.0</p>
                    </div>
                    <button id="btn-fetch-ai" class="bg-indigo-600 text-white px-8 py-3 rounded-xl font-black hover:bg-indigo-700 shadow-xl shadow-indigo-200 transition-all flex items-center gap-2 active:scale-95 disabled:opacity-50">
                        <i class="fa-solid fa-wand-magic-sparkles animate-pulse"></i>
                        Suggestion Traitement AI
                    </button>
                </div>

                <!-- LOADING STATE -->
                <div id="ai-loading" class="hidden">
                    <div class="flex flex-col items-center justify-center p-12 bg-white rounded-3xl border border-indigo-100">
                        <div class="w-12 h-12 border-4 border-indigo-100 border-t-indigo-600 rounded-full animate-spin mb-4"></div>
                        <p class="text-indigo-900 font-black text-sm animate-pulse">L'IA analyse votre profil clinique...</p>
                    </div>
                </div>

                <!-- RESULTS -->
                <div id="ai-results" class="hidden space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="ai-items-list">
                        <!-- JS Injection -->
                    </div>

                    <div class="flex items-center justify-between p-6 bg-indigo-900 rounded-3xl text-white shadow-xl">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
                                <i class="fa-solid fa-file-medical text-indigo-400"></i>
                            </div>
                            <p class="text-sm font-bold">Générer l'ordonnance correspondante ?</p>
                        </div>
                        <form method="post" action="{{ path('app_fiche_auto_fill_prescription', {'id': fiche.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('autofill' ~ fiche.id) }}">
                            <button type="submit" class="bg-white text-indigo-900 px-6 py-2 rounded-lg font-black hover:bg-slate-100">
                                <i class="fa-solid fa-paper-plane mr-2"></i> Valider
                            </button>
                        </form>
                    </div>
                </div>
                
                <div class="mt-6 flex items-center justify-center gap-2 text-[9px] font-bold text-indigo-400 uppercase">
                    <i class="fa-solid fa-shield-halved"></i>
                    Avertissement : Une validation par un docteur est indispensable.
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('btn-fetch-ai').addEventListener('click', async function() {
    const btn = this;
    const loader = document.getElementById('ai-loading');
    const results = document.getElementById('ai-results');
    const list = document.getElementById('ai-items-list');

    btn.disabled = true;
    loader.classList.remove('hidden');
    results.classList.add('hidden');
    list.innerHTML = '';

    try {
        const response = await fetch("{{ path('app_fiche_fetch_ai_suggestions', {'id': fiche.id}) }}");
        const data = await response.json();

        if (data.success && data.items && data.items.length > 0) {
            data.items.forEach(item => {
                const card = document.createElement('div');
                card.className = "p-5 bg-white rounded-2xl border border-indigo-100 shadow-sm";
                card.innerHTML = `
                    <div class="flex justify-between items-start mb-2">
                        <p class="font-black text-slate-800 text-sm">${item.medicamentName}</p>
                        <span class="text-[9px] font-black uppercase text-indigo-500 bg-indigo-50 px-2 py-0.5 rounded-md">${item.nbJours} Jours</span>
                    </div>
                    <p class="text-[10px] text-slate-500 italic mb-2">Frequence: ${item.frequenceParJour}x / jour</p>
                    <p class="text-[9px] text-slate-400 leading-tight">${item.reason}</p>
                `;
                list.appendChild(card);
            });
            results.classList.remove('hidden');
        } else {
            alert("Aucun traitement optimal trouvé dans le catalogue.");
        }
    } catch (e) {
        alert("Erreur de connexion avec le service OpenAI.");
    } finally {
        loader.classList.add('hidden');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-rotate-right"></i> Recalculer';
    }
});
</script>
{% endblock %}
