{% extends 'baseFront.html.twig' %}

{% block title %}
<h1 class="text-2xl font-black text-gray-800 tracking-tight">Bonjour, {{ app.user.prenom }} 👋</h1>
{% endblock %}

{% block body %}
<div class="px-8 py-8 space-y-10">
    <!-- Welcome Section -->
    <div class="relative overflow-hidden bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[2.5rem] p-10 text-white shadow-2xl shadow-blue-200 group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-32 -mt-32 blur-3xl group-hover:bg-white/20 transition-all duration-700"></div>
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="space-y-4">
                <span class="px-4 py-1.5 bg-white/20 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest">Aperçu de Santé</span>
                <h2 class="text-4xl font-black italic">Prenez soin de vous au quotidien.</h2>
                <p class="text-blue-100 max-w-xl font-medium leading-relaxed">
                    Retrouvez ici toutes vos données médicales, vos ordonnances en cours et suivez votre évolution clinique en temps réel.
                </p>
            </div>
            <div class="flex gap-4">
                <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center text-3xl hover:scale-110 transition-transform">
                    <i class="fa-solid fa-stethoscope"></i>
                </div>
                <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center text-3xl hover:scale-110 transition-transform">
                    <i class="fa-solid fa-pills"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6">
        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-gray-400">Rendez-vous</p>
            <p class="text-3xl font-black text-gray-800 mt-2">{{ stats.rdvCount }}</p>
            <p class="text-xs text-gray-500 mt-1">Total dans votre espace</p>
        </div>
        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-gray-400">Missions ouvertes</p>
            <p class="text-3xl font-black text-gray-800 mt-2">{{ stats.missionsOpen }}</p>
            <p class="text-xs text-gray-500 mt-1">Disponibles maintenant</p>
        </div>
        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-gray-400">Mes candidatures</p>
            <p class="text-3xl font-black text-gray-800 mt-2">{{ stats.myCandidatures }}</p>
            <p class="text-xs text-gray-500 mt-1">Dans le module bénévolat</p>
        </div>
        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-gray-400">Forum + Solidarité</p>
            <p class="text-3xl font-black text-gray-800 mt-2">{{ stats.forumTopics + stats.annonces + stats.donations }}</p>
            <p class="text-xs text-gray-500 mt-1">{{ stats.forumTopics }} sujets, {{ stats.annonces }} annonces, {{ stats.donations }} dons</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white rounded-3xl p-7 border border-gray-100 shadow-lg">
            <div class="flex items-start justify-between gap-6">
                <div>
                    <h3 class="text-lg font-black text-gray-800">Prochain rendez-vous</h3>
                    {% if nextRdv %}
                        <p class="text-2xl font-black text-blue-700 mt-2">
                            {{ nextRdv.date|date('d/m/Y') }} à {{ nextRdv.hdebut|date('H:i') }}
                        </p>
                        <p class="text-sm text-gray-600 mt-1">Dr. {{ nextRdv.medecin ?: 'Non défini' }}</p>
                        <p class="text-sm text-gray-500 mt-1">Motif: {{ nextRdv.motif ?: 'N/A' }}</p>
                    {% else %}
                        <p class="text-sm text-gray-500 mt-3">Aucun rendez-vous à venir.</p>
                    {% endif %}
                </div>
                <a href="{{ path('showAllRdvfront') }}" class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-xl font-bold text-sm hover:bg-blue-700 transition">
                    <i class="fa-solid fa-calendar-check"></i> Voir mes RDV
                </a>
            </div>
        </div>

        <div class="bg-gradient-to-br from-orange-500 to-amber-500 rounded-3xl p-7 text-white shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-orange-100">Interface principale</p>
            <h3 class="text-xl font-black mt-2">Pilotage global</h3>
            <p class="text-sm text-orange-50 mt-2">Accès rapide à tous vos modules métiers.</p>
            <div class="mt-5 grid grid-cols-2 gap-2 text-xs font-bold">
                <a href="{{ path('patient_dossier') }}" class="bg-white/20 rounded-lg px-3 py-2">Suivi Santé</a>
                <a href="{{ path('app_missions_index') }}" class="bg-white/20 rounded-lg px-3 py-2">Bénévolat</a>
                <a href="{{ path('app_forum_index') }}" class="bg-white/20 rounded-lg px-3 py-2">Forum</a>
                <a href="{{ path('app_donation_index') }}" class="bg-white/20 rounded-lg px-3 py-2">Annonces & Dons</a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white rounded-3xl p-7 border border-gray-100 shadow-lg">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-black text-gray-800">Mes missions bénévoles en cours</h3>
                <a href="{{ path('app_front_volunteer_index') }}" class="text-sm font-bold text-blue-600 hover:text-blue-700 transition">Mes candidatures</a>
            </div>

            <div class="space-y-4">
                {% for mission in ongoingVolunteerMissions %}
                    <a href="{{ path('app_mission_show', {id: mission.id}) }}" class="block p-4 rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-md transition">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-start gap-4">
                                <img
                                    src="{{ mission.photo ? asset('uploads/missions/' ~ mission.photo) : 'https://images.unsplash.com/photo-1593113598332-cd288d649433?w=300' }}"
                                    alt="{{ mission.titre }}"
                                    class="w-16 h-16 rounded-xl object-cover border border-gray-100"
                                >
                                <div>
                                <p class="font-black text-gray-800">{{ mission.titre }}</p>
                                <p class="text-sm text-gray-500 mt-1">{{ mission.lieu }}</p>
                                <p class="text-xs text-gray-400 mt-2">
                                    Du {{ mission.dateDebut|date('d/m/Y') }} au {{ mission.dateFin|date('d/m/Y') }}
                                </p>
                                </div>
                            </div>
                            <span class="text-xs font-bold bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full">En cours</span>
                        </div>
                    </a>
                {% else %}
                    <div class="p-6 rounded-2xl border border-dashed border-gray-200 text-sm text-gray-500">
                        Aucune mission en cours pour aujourd'hui.
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="bg-gradient-to-br from-violet-600 to-indigo-600 rounded-3xl p-7 text-white shadow-lg">
            <p class="text-xs font-black uppercase tracking-widest text-violet-100">Bénévolat</p>
            <h3 class="text-xl font-black mt-2">Trouver une mission</h3>
            <p class="text-sm text-violet-50 mt-2">Consultez les nouvelles missions qui correspondent à votre profil.</p>
            <a href="{{ path('app_missions_index') }}" class="inline-flex items-center gap-2 mt-5 bg-white text-indigo-700 px-4 py-2 rounded-xl font-bold text-sm hover:bg-indigo-50 transition">
                <i class="fa-solid fa-hand-holding-heart"></i> Voir les missions
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Latest Fiche -->
            <div class="bg-white rounded-[2.5rem] p-10 border border-gray-100 shadow-xl shadow-gray-200/50 relative overflow-hidden group">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xl font-black text-gray-800 flex items-center gap-3">
                        <i class="fa-solid fa-file-medical text-emerald-500 text-2xl"></i>
                        Dernière Analyse
                    </h3>
                    {% if latestFiche %}
                        <a href="{{ path('patient_fiche_show', {id: latestFiche.id}) }}" class="text-sm font-black text-blue-600 hover:text-blue-700 transition-colors">Voir tout</a>
                    {% endif %}
                </div>

                {% if latestFiche %}
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 hover:shadow-lg transition-all hover:-translate-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Poids</p>
                            <p class="text-2xl font-black text-slate-700">{{ latestFiche.poids }}<small class="text-xs ml-1 opacity-50">kg</small></p>
                        </div>
                        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 hover:shadow-lg transition-all hover:-translate-y-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Tension</p>
                            <p class="text-2xl font-black text-slate-700">{{ latestFiche.tension }}</p>
                        </div>
                        <div class="p-6 bg-emerald-50 rounded-3xl border border-emerald-100 hover:shadow-lg transition-all hover:-translate-y-1">
                            <p class="text-[10px] font-black text-emerald-400 uppercase tracking-widest mb-1">Diagnostic</p>
                            <p class="text-sm font-black text-emerald-600 leading-tight">{{ latestFiche.libelleMaladie }}</p>
                        </div>
                        <div class="p-6 bg-blue-50 rounded-3xl border border-blue-100 hover:shadow-lg transition-all hover:-translate-y-1">
                            <p class="text-[10px] font-black text-blue-400 uppercase tracking-widest mb-1">Gravité</p>
                            <p class="text-sm font-black text-blue-600">{{ latestFiche.gravite }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="text-center py-10 opacity-50">
                        <i class="fa-solid fa-clipboard-question text-4xl mb-4"></i>
                        <p class="font-bold">Aucune fiche médicale trouvée.</p>
                    </div>
                {% endif %}
            </div>

            <!-- Health Chart -->
            <div class="bg-white rounded-[2.5rem] p-10 border border-gray-100 shadow-xl shadow-gray-200/50">
                <h3 class="text-xl font-black text-gray-800 mb-8 flex items-center gap-3">
                    <i class="fa-solid fa-chart-area text-blue-500"></i>
                    Évolution de l'état
                </h3>
                <div class="h-64">
                    <canvas id="healthChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
            <!-- Quick Prescription List -->
            <div class="bg-indigo-900 rounded-[2.5rem] p-8 text-white shadow-2xl relative overflow-hidden group">
                <i class="fa-solid fa-receipt absolute -right-4 -bottom-4 text-8xl text-white/5 group-hover:rotate-12 transition-transform duration-500"></i>
                <h3 class="text-lg font-black mb-6 relative z-10">Ordonnances Récentes</h3>
                <div class="space-y-4 relative z-10">
                    {% for ord in recentOrdonnances %}
                        <a href="{{ path('patient_ordonnance_show', {id: ord.id}) }}" class="flex items-center gap-4 p-4 bg-white/5 hover:bg-white/10 rounded-2xl border border-white/10 transition-all border-l-4 border-l-indigo-400">
                            <div class="w-10 h-10 bg-indigo-500/20 rounded-xl flex items-center justify-center text-indigo-300">
                                <i class="fa-solid fa-file-prescription"></i>
                            </div>
                            <div>
                                <p class="text-sm font-black">#ORD-{{ ord.id }}</p>
                                <p class="text-[10px] text-indigo-300 font-bold uppercase">{{ ord.dureeTraitement }} Jours de traitement</p>
                            </div>
                        </a>
                    {% else %}
                        <p class="text-xs text-indigo-300 italic">Aucune ordonnance.</p>
                    {% endfor %}
                </div>
            </div>

            <!-- Profile Completion Card -->
            <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 shadow-xl text-center flex flex-col items-center">
                <div class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center text-blue-600 mb-4 shadow-inner">
                    <i class="fa-solid fa-user-check text-3xl"></i>
                </div>
                <h4 class="font-black text-gray-800 mb-1">{{ app.user.prenom }} {{ app.user.nom }}</h4>
                <p class="text-xs text-gray-400 font-bold mb-6">{{ app.user.email }}</p>
                <div class="w-full bg-gray-100 h-2 rounded-full mb-2">
                    <div class="bg-blue-600 h-2 rounded-full" style="width: 85%"></div>
                </div>
                <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest">Profil complété à 85%</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
