{% extends 'baseFront.html.twig' %}

{% block title %}Mes Candidatures{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-800 mb-8 border-b pb-4">Mes Candidatures</h1>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-lg border px-4 py-3 text-sm
                {% if label == 'success' %}border-green-200 bg-green-50 text-green-800
                {% elseif label == 'warning' %}border-yellow-200 bg-yellow-50 text-yellow-800
                {% else %}border-blue-200 bg-blue-50 text-blue-800{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid gap-6">
        {% for volunteer in volunteers %}
            {% set status = volunteer.statut|default('En attente') %}
            {% set statusKey = status|lower %}

            <div class="bg-white rounded-lg shadow-md p-6 flex flex-col md:flex-row justify-between items-center border-l-4
                {% if statusKey == 'acceptee' or statusKey == 'validee' or statusKey == 'validée' %}border-green-500
                {% elseif statusKey == 'refusee' or statusKey == 'refusee' or statusKey == 'refusée' %}border-red-500
                {% else %}border-yellow-500{% endif %}">

                <div class="mb-4 md:mb-0">
                    <h2 class="text-xl font-bold text-gray-800">{{ volunteer.mission.titre }}</h2>
                    <p class="text-sm text-gray-500">Postule le {{ "now"|date("d/m/Y") }} (Simulation date)</p>

                    <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-bold
                        {% if statusKey == 'acceptee' or statusKey == 'validee' or statusKey == 'validée' %}bg-green-100 text-green-700
                        {% elseif statusKey == 'refusee' or statusKey == 'refusee' or statusKey == 'refusée' %}bg-red-100 text-red-700
                        {% else %}bg-yellow-100 text-yellow-700{% endif %}">
                        {{ status }}
                    </span>
                </div>

                {% if statusKey == 'en attente' %}
                    <div class="flex gap-3">
                        <a href="{{ path('app_front_volunteer_edit', {'id': volunteer.id}) }}" class="text-blue-600 hover:text-blue-800 font-medium">
                            <i class="fa-solid fa-pen"></i> Modifier
                        </a>

                        <form method="post" action="{{ path('app_front_volunteer_delete', {'id': volunteer.id}) }}" onsubmit="return confirm('Voulez-vous vraiment annuler votre candidature ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ volunteer.id) }}">
                            <button class="text-red-600 hover:text-red-800 font-medium">
                                <i class="fa-solid fa-trash"></i> Annuler
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div class="text-center py-12 bg-gray-50 rounded-lg">
                <p class="text-gray-500 text-lg">Vous n'avez postule a aucune mission pour le moment.</p>
                <a href="{{ path('app_missions_index') }}" class="inline-block mt-4 text-blue-600 font-bold hover:underline">Voir les missions disponibles</a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
