{# ============================================================ #}
{# CHATBOT MEDICAL VITALTECH                                    #}
{# Inclure dans baseFront.html.twig : avant </body>            #}
{# {% include 'rdv/front/_chatbot.html.twig' %}                #}
{# ============================================================ #}

<style>
@keyframes chatPulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:0.5; transform:scale(1.4); }
}
@keyframes chatSlideUp {
    from { opacity:0; transform:translateY(24px) scale(0.95); }
    to   { opacity:1; transform:translateY(0) scale(1); }
}
@keyframes chatBounce {
    0%,60%,100% { transform:translateY(0); }
    30%         { transform:translateY(-6px); }
}
#chatbotWindow { animation: chatSlideUp 0.3s ease; }
</style>

{# ── Bouton flottant ── #}
<button id="chatbotBtn" onclick="chatbotToggle()"
    style="position:fixed;bottom:28px;right:28px;width:56px;height:56px;border-radius:50%;
           background:linear-gradient(135deg,#2563eb,#1d4ed8);border:none;cursor:pointer;
           display:flex;align-items:center;justify-content:center;
           box-shadow:0 8px 32px rgba(37,99,235,0.45);z-index:9998;transition:transform 0.2s;"
    onmouseover="this.style.transform='scale(1.1)'"
    onmouseout="this.style.transform='scale(1)'"
    title="Assistant médical">
    <svg id="chatbotIconOpen" width="24" height="24" viewBox="0 0 24 24" fill="white">
        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-3 11H7v-2h10v2zm0-3H7V8h10v2z"/>
    </svg>
    <svg id="chatbotIconClose" width="22" height="22" viewBox="0 0 24 24" fill="white" style="display:none;">
        <path d="M19 6.4L17.6 5 12 10.6 6.4 5 5 6.4 10.6 12 5 17.6 6.4 19 12 13.4 17.6 19 19 17.6 13.4 12z"/>
    </svg>
    <span style="position:absolute;top:3px;right:3px;width:11px;height:11px;background:#22c55e;
                 border-radius:50%;border:2px solid white;animation:chatPulse 2s infinite;"></span>
</button>

{# ── Fenêtre chat ── #}
<div id="chatbotWindow"
    style="display:none;position:fixed;bottom:96px;right:28px;width:360px;height:520px;
           border-radius:20px;background:white;box-shadow:0 20px 60px rgba(0,0,0,0.16);
           flex-direction:column;overflow:hidden;z-index:9997;">

    {# Header #}
    <div style="background:linear-gradient(135deg,#2563eb,#1e40af);padding:14px 16px;
                display:flex;align-items:center;gap:10px;flex-shrink:0;">
        <div style="width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,0.2);
                    display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">
            🩺
        </div>
        <div style="flex:1;">
            <p style="margin:0;color:white;font-weight:700;font-size:14px;">Assistant VitalTech</p>
            <p style="margin:0;color:rgba(255,255,255,0.75);font-size:11px;">
                <span style="color:#4ade80;">●</span> En ligne · Répond instantanément
            </p>
        </div>
        <button onclick="chatbotToggle()"
                style="background:rgba(255,255,255,0.15);border:none;border-radius:8px;
                       width:28px;height:28px;cursor:pointer;color:white;font-size:14px;
                       display:flex;align-items:center;justify-content:center;">✕</button>
    </div>

    {# Messages #}
    <div id="chatbotMessages"
        style="flex:1;overflow-y:auto;padding:14px 12px;display:flex;flex-direction:column;
               gap:10px;background:#f8fafc;">

        {# Message initial #}
        <div style="display:flex;align-items:flex-end;gap:8px;">
            <div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#1e40af);
                        display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">🩺</div>
            <div style="max-width:78%;padding:10px 13px;border-radius:16px 16px 16px 4px;
                        background:white;border:1px solid #e2e8f0;font-size:13px;color:#1e293b;
                        line-height:1.5;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                Bonjour 👋 Je suis votre assistant médical VitalTech.<br>
                Décrivez vos symptômes, je vous oriente vers le bon médecin.
            </div>
        </div>

        {# Suggestions rapides #}
        <div id="chatbotSuggestions" style="padding-left:34px;display:flex;flex-direction:column;gap:5px;">
            <p style="margin:0 0 3px;font-size:10px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;">
                Suggestions
            </p>
            <button onclick="chatbotSend('J\'ai des maux de tête fréquents')" class="chatbot-suggestion">💆 Maux de tête fréquents</button>
            <button onclick="chatbotSend('J\'ai des douleurs dans la poitrine')" class="chatbot-suggestion">❤️ Douleurs thoraciques</button>
            <button onclick="chatbotSend('J\'ai des problèmes de vision')" class="chatbot-suggestion">👁️ Problèmes de vision</button>
            <button onclick="chatbotSend('Je veux un bilan de santé général')" class="chatbot-suggestion">🩺 Bilan de santé</button>
        </div>
    </div>

    {# Input #}
    <div style="padding:10px 12px;border-top:1px solid #e2e8f0;background:white;
                display:flex;gap:8px;align-items:flex-end;flex-shrink:0;">
        <textarea id="chatbotInput" rows="1" placeholder="Décrivez vos symptômes..."
            onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();chatbotSend();}"
            oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,80)+'px';"
            style="flex:1;border:1.5px solid #e2e8f0;border-radius:10px;padding:9px 12px;
                   font-size:13px;outline:none;resize:none;font-family:inherit;
                   color:#1e293b;line-height:1.4;max-height:80px;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2563eb'"
            onblur="this.style.borderColor='#e2e8f0'"></textarea>
        <button id="chatbotSendBtn" onclick="chatbotSend()"
            style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                   background:linear-gradient(135deg,#2563eb,#1d4ed8);border:none;
                   cursor:pointer;display:flex;align-items:center;justify-content:center;
                   box-shadow:0 2px 8px rgba(37,99,235,0.35);transition:opacity 0.2s;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
        </button>
    </div>

    {# Footer #}
    <div style="padding:5px 12px 8px;background:white;text-align:center;">
        <p style="margin:0;font-size:10px;color:#cbd5e1;">
            ⚕️ Pas un avis médical · Urgence : <strong>190</strong>
        </p>
    </div>
</div>

<style>
.chatbot-suggestion {
    background:white;border:1px solid #e2e8f0;border-radius:10px;
    padding:6px 12px;font-size:12px;color:#2563eb;cursor:pointer;
    text-align:left;transition:all 0.15s;font-weight:500;font-family:inherit;
}
.chatbot-suggestion:hover {
    background:#eff6ff;border-color:#93c5fd;
}
#chatbotMessages::-webkit-scrollbar { width:4px; }
#chatbotMessages::-webkit-scrollbar-track { background:transparent; }
#chatbotMessages::-webkit-scrollbar-thumb { background:#cbd5e1;border-radius:4px; }
</style>

<script>
// ── État ──────────────────────────────────────────────
let chatbotOpen    = false;
let chatbotHistory = [];  // { role, content }[]
let chatbotLoading = false;

// ── Toggle fenêtre ────────────────────────────────────
function chatbotToggle() {
    chatbotOpen = !chatbotOpen;
    const win  = document.getElementById('chatbotWindow');
    const ico1 = document.getElementById('chatbotIconOpen');
    const ico2 = document.getElementById('chatbotIconClose');

    if (chatbotOpen) {
        win.style.display = 'flex';
        ico1.style.display = 'none';
        ico2.style.display = 'block';
        setTimeout(() => document.getElementById('chatbotInput').focus(), 200);
    } else {
        win.style.display = 'none';
        ico1.style.display = 'block';
        ico2.style.display = 'none';
    }
}

// ── Envoyer message ───────────────────────────────────
async function chatbotSend(forcedText) {
    if (chatbotLoading) return;

    const input = document.getElementById('chatbotInput');
    const text  = (forcedText || input.value).trim();
    if (!text) return;

    // Cacher suggestions
    const sugg = document.getElementById('chatbotSuggestions');
    if (sugg) sugg.style.display = 'none';

    input.value = '';
    input.style.height = 'auto';

    // Ajouter message user
    chatbotHistory.push({ role: 'user', content: text });
    chatbotAppendMessage('user', text);
    chatbotLoading = true;

    // Typing indicator
    const typingId = chatbotAppendTyping();

    try {
        const res  = await fetch('/api/chatbot', {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({ messages: chatbotHistory }),
        });
        const data = await res.json();

        // Supprimer typing
        document.getElementById(typingId)?.remove();

        if (data.error) {
            chatbotAppendMessage('assistant', '❌ ' + data.error);
        } else {
            const reply = data.text || data.content?.[0]?.text || 'Désolé, une erreur s\'est produite.';
            chatbotHistory.push({ role: 'assistant', content: reply });
            chatbotAppendMessage('assistant', reply);
        }
    } catch (e) {
        document.getElementById(typingId)?.remove();
        chatbotAppendMessage('assistant', '❌ Erreur de connexion. Réessayez.');
    } finally {
        chatbotLoading = false;
    }
}

// ── Afficher un message ───────────────────────────────
function chatbotAppendMessage(role, text) {
    const container = document.getElementById('chatbotMessages');
    const isUser    = role === 'user';

    const wrapper = document.createElement('div');
    wrapper.style.cssText = `display:flex;align-items:flex-end;gap:8px;
        justify-content:${isUser ? 'flex-end' : 'flex-start'};`;

    if (!isUser) {
        wrapper.innerHTML = `<div style="width:26px;height:26px;border-radius:50%;
            background:linear-gradient(135deg,#2563eb,#1e40af);
            display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">🩺</div>`;
    }

    const bubble = document.createElement('div');
    bubble.style.cssText = `max-width:78%;padding:10px 13px;font-size:13px;line-height:1.5;
        white-space:pre-wrap;
        border-radius:${isUser ? '16px 16px 4px 16px' : '16px 16px 16px 4px'};
        background:${isUser ? 'linear-gradient(135deg,#2563eb,#1d4ed8)' : 'white'};
        color:${isUser ? 'white' : '#1e293b'};
        border:${isUser ? 'none' : '1px solid #e2e8f0'};
        box-shadow:${isUser ? '0 2px 12px rgba(37,99,235,0.3)' : '0 1px 4px rgba(0,0,0,0.06)'};`;
    bubble.textContent = text;

    wrapper.appendChild(bubble);
    container.appendChild(wrapper);
    container.scrollTop = container.scrollHeight;
}

// ── Typing indicator ──────────────────────────────────
function chatbotAppendTyping() {
    const container = document.getElementById('chatbotMessages');
    const id        = 'typing_' + Date.now();

    const wrapper = document.createElement('div');
    wrapper.id    = id;
    wrapper.style.cssText = 'display:flex;align-items:flex-end;gap:8px;';
    wrapper.innerHTML = `
        <div style="width:26px;height:26px;border-radius:50%;
            background:linear-gradient(135deg,#2563eb,#1e40af);
            display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">🩺</div>
        <div style="background:white;border:1px solid #e2e8f0;border-radius:16px 16px 16px 4px;
            padding:11px 16px;display:flex;gap:4px;align-items:center;">
            <div style="width:7px;height:7px;border-radius:50%;background:#94a3b8;animation:chatBounce 1.2s ease 0s infinite;"></div>
            <div style="width:7px;height:7px;border-radius:50%;background:#94a3b8;animation:chatBounce 1.2s ease 0.2s infinite;"></div>
            <div style="width:7px;height:7px;border-radius:50%;background:#94a3b8;animation:chatBounce 1.2s ease 0.4s infinite;"></div>
        </div>`;

    container.appendChild(wrapper);
    container.scrollTop = container.scrollHeight;
    return id;
}
</script>
