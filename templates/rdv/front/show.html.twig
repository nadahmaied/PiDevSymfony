        const top=data.rappels[0];
        if(top.niveau==='urgent'){
            banner.style.cssText='display:block;position:fixed;top:0;left:0;right:0;z-index:9999;background:linear-gradient(135deg,#dc2626,#b91c1c);color:white;padding:1rem 2rem;animation:blink 1s infinite;box-shadow:0 4px 20px rgba(220,38,38,0.5);';
            banner.innerHTML=`<div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;"><div style="display:flex;align-items:center;gap:1rem;"><i class="fa-solid fa-triangle-exclamation" style="font-size:1.5rem;"></i><div><p style="font-weight:800;font-size:1rem;">${top.message}</p><p style="font-size:0.75rem;opacity:0.9;">Cliquez pour fermer</p></div></div><button onclick="fermerRappel()" style="background:rgba(255,255,255,0.2);border:2px solid white;color:white;padding:0.5rem 1rem;border-radius:0.5rem;font-weight:700;cursor:pointer;">✓ OK, J'ai vu !</button></div>`;
