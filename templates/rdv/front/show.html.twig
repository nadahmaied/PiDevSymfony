function openAddRdvModal() {
    fetch('{{ path('AjouterRdv') }}', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
    .then(res => res.text()).then(html => {
        document.getElementById('rdvModalContent').innerHTML = html;
        openRdvModal(); attachFormSubmit();
    });
}
function attachFormSubmit() {
    const form = document.querySelector('#rdvModalContent form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
        e.preventDefault(); e.stopPropagation();
        fetch('{{ path('AjouterRdv') }}', { method:'POST', body:new FormData(form), headers:{'X-Requested-With':'XMLHttpRequest'} })
        .then(async res => { const ct=res.headers.get('content-type')||''; return ct.includes('application/json') ? res.json().then(d=>({type:'json',data:d})) : res.text().then(d=>({type:'html',data:d})); })
        .then(result => { if(result.type==='json'&&result.data.success){closeRdvModal();window.location.reload();} else if(result.type==='html'){document.getElementById('rdvModalContent').innerHTML=result.data;attachFormSubmit();} })
        .catch(err => console.error(err));
    });
}
function openEditRdvModal(id) {
    fetch(`{{ path('editForm', {id: '__ID__'}) }}`.replace('__ID__', id), { headers:{'X-Requested-With':'XMLHttpRequest'} })
    .then(res => res.text()).then(html => {
        document.getElementById('rdvModalContent').innerHTML = html; openRdvModal();
        const form = document.getElementById('editRdvForm');
        if (!form) return;
        form.addEventListener('submit', function(e) {
            e.preventDefault(); e.stopPropagation();
            fetch(form.action, { method:'POST', body:new FormData(form), headers:{'X-Requested-With':'XMLHttpRequest'} })
            .then(async res => { const ct=res.headers.get('content-type')||''; return ct.includes('application/json') ? res.json().then(d=>({type:'json',data:d})) : res.text().then(d=>({type:'html',data:d})); })
            .then(result => { if(result.type==='json'&&result.data.success){closeRdvModal();window.location.reload();} else if(result.type==='html'){document.getElementById('rdvModalContent').innerHTML=result.data;openEditRdvModal(id);} })
            .catch(err => console.error(err));
        });
    });
}
function openRdvModal()   { document.getElementById('rdvModal').classList.remove('hidden'); }
function closeRdvModal()  { document.getElementById('rdvModal').classList.add('hidden'); }
function openDeleteModal(id, token) {
    const modal=document.getElementById('deleteModal'), card=document.getElementById('deleteCard');
    document.getElementById('deleteForm').action=`/delete/${id}`;
    document.getElementById('deleteToken').value=token;
    modal.classList.remove('hidden');
    setTimeout(()=>{card.classList.remove('scale-95','opacity-0');card.classList.add('scale-100','opacity-100');},10);
}
function closeDeleteModal() {
    const modal=document.getElementById('deleteModal'), card=document.getElementById('deleteCard');
    card.classList.remove('scale-100','opacity-100'); card.classList.add('scale-95','opacity-0');
    setTimeout(()=>{ modal.classList.add('hidden'); },200);
}
function openSpecialisteModal()  { document.getElementById('specialisteModal').classList.remove('hidden'); }
function closeSpecialisteModal() { document.getElementById('specialisteModal').classList.add('hidden'); }
function selectSpecialite(sp) {
    document.getElementById('specialiteInput').value=sp;
    document.querySelectorAll('.specialite-tag').forEach(btn=>{btn.classList.remove('bg-blue-600','text-white','border-blue-600');btn.classList.add('text-slate-600','border-slate-200');});
