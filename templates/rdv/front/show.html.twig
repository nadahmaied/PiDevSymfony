{% extends 'baseFront.html.twig' %}

{% block body %}

{# ===== BANNIERE RAPPEL ===== #}
<div id="rappelBanner" style="display:none; position:fixed; top:0; left:0; right:0; z-index:9999;"></div>

<div class="flex-1 overflow-y-auto bg-slate-50 p-4 md:p-8 no-scrollbar">
    <div class="flex justify-between mb-4">
        <a href="{{ path('historique') }}"
           class="bg-white hover:bg-slate-50 text-slate-700 px-5 py-2.5 rounded-xl font-bold shadow-lg flex items-center gap-2 transition border border-slate-200">
            <i class="fa-solid fa-clock-rotate-left"></i>
            Historique
        </a>
        <button
            onclick="openAddRdvModal()"
            class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl font-bold shadow-lg flex items-center gap-2 transition">
            <i class="fa-solid fa-plus"></i>
            Ajouter RDV
        </button>
    </div>
    {% include 'rdv/front/modal.html.twig' %}

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">

        <div class="lg:col-span-8 space-y-6">

            {% if prochainRdv %}
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 text-white shadow-xl relative overflow-hidden flex flex-col sm:flex-row items-center justify-between gap-6">
                <div class="relative z-10">
                    <div class="inline-block bg-blue-500/30 border border-blue-400/30 rounded-full px-3 py-1 text-xs font-bold mb-2">
                        <i class="fa-solid fa-bell animate-pulse mr-1"></i> Prochain Rendez-vous
                    </div>
                    <h2 class="text-2xl font-bold mb-1">{{ prochainRdv.medecin }}</h2>
                    <p class="text-blue-100 mb-4">{{ prochainRdv.motif ?? 'Consultation' }}</p>
                    <div class="flex gap-3">
                        <button class="bg-white text-blue-700 px-4 py-2 rounded-lg text-sm font-bold shadow hover:bg-blue-50 transition">
                            <i class="fa-solid fa-video mr-1"></i> Lancer Visio
                        </button>
                        <a href="{{ path('showOne', { id: prochainRdv.id }) }}"
                           class="bg-blue-800/50 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-800 transition">
                            Détails
                        </a>
                    </div>
                </div>
                <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-4 text-center min-w-[100px]">
                    <span class="block text-sm uppercase tracking-widest text-blue-200">{{ prochainRdv.date|date('M') }}</span>
                    <span class="block text-4xl font-bold text-white">{{ prochainRdv.date|date('d') }}</span>
                    <span class="block text-sm font-medium text-blue-100 mt-1">{{ prochainRdv.hdebut|date('H:i') }}</span>
                </div>
                <i class="fa-solid fa-user-doctor absolute -right-6 -bottom-6 text-9xl text-white opacity-10"></i>
            </div>
            {% else %}
            <div class="bg-gradient-to-br from-slate-400 to-slate-500 rounded-2xl p-6 text-white shadow-xl relative overflow-hidden flex items-center justify-center">
                <div class="text-center">
                    <i class="fa-solid fa-calendar-check text-4xl mb-3 opacity-60"></i>
                    <p class="font-bold text-lg">Aucun prochain rendez-vous</p>
                    <p class="text-slate-200 text-sm mt-1">Ajoutez un RDV pour le voir ici</p>
                </div>
            </div>
            {% endif %}

            {# ===== ONGLETS + BARRE DE RECHERCHE ===== #}
            <div class="flex items-center justify-between border-b border-slate-200 pb-1 gap-4 flex-wrap">
                <div class="flex gap-6 items-center">
                    <button id="tab-avenir"  onclick="filterTab('avenir')"  class="text-blue-600 font-bold border-b-2 border-blue-600 pb-3 px-1 transition">À venir</button>
                    <button id="tab-passes"  onclick="filterTab('passes')"  class="text-slate-500 font-medium hover:text-slate-800 pb-3 px-1 transition">📅 Passés</button>
                    <button id="tab-annules" onclick="filterTab('annules')" class="text-slate-500 font-medium hover:text-slate-800 pb-3 px-1 transition">Annulés</button>
                </div>

                {# Barre de recherche #}
                <div style="position:relative; z-index:100;">
                    <div id="searchBox"
                         style="display:flex; align-items:center; gap:8px; background:white; border:2px solid #e2e8f0; border-radius:1rem; padding:8px 14px; box-shadow:0 1px 4px rgba(0,0,0,0.06); width:180px; transition: width 0.35s ease, border-color 0.3s, box-shadow 0.3s;">
                        <i id="searchIcon" class="fa-solid fa-magnifying-glass" style="color:#94a3b8; font-size:0.8rem; flex-shrink:0; transition:color 0.3s;"></i>
                        <input type="text" id="searchRdv" placeholder="Rechercher..." autocomplete="off"
                            style="border:none; outline:none; background:transparent; font-size:0.875rem; color:#334155; width:100%; font-family:inherit;">
                        <i id="searchSpinner" class="fa-solid fa-spinner fa-spin" style="color:#3b82f6; font-size:0.8rem; display:none; flex-shrink:0;"></i>
                        <button id="clearSearch" onclick="clearSearchInput()"
                                style="display:none; background:none; border:none; cursor:pointer; padding:0; color:#94a3b8; flex-shrink:0;"
                                onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#94a3b8'">
                            <i class="fa-solid fa-xmark" style="font-size:0.75rem;"></i>
                        </button>
                    </div>
                    <div id="searchDropdown"
                         style="display:none; position:absolute; top:calc(100% + 8px); left:0; right:0; min-width:300px; background:white; border:1px solid #e2e8f0; border-radius:1rem; box-shadow:0 10px 40px rgba(0,0,0,0.12); overflow:hidden;">
                        <div id="searchDropdownContent"></div>
                    </div>
                </div>
            </div>

            {# ===== LISTE DES RDV — data-date + data-statut sur chaque carte ===== #}
            <div id="rdvList" class="space-y-4">
                {% for rdv in rdvs %}
                <div class="rdv-card bg-white rounded-xl p-5 shadow-sm border border-slate-100 flex flex-col sm:flex-row items-start sm:items-center gap-5 hover:border-orange-200 transition group"
                     data-date="{{ rdv.date|date('Y-m-d') }}"
                     data-statut="{{ rdv.statut }}">
                    <div class="flex-shrink-0 w-16 h-16 bg-orange-50 rounded-xl flex flex-col items-center justify-center text-orange-600 border border-orange-100 group-hover:bg-orange-100 transition">
                        <span class="text-xs font-bold uppercase">{{ rdv.date|date('M') }}</span>
                        <span class="text-xl font-bold">{{ rdv.date|date('d') }}</span>
                    </div>
                    <div class="flex-1">
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="font-bold text-slate-800 text-lg">{{ rdv.medecin }}</h3>
                                <p class="text-slate-500 text-sm">{{ rdv.motif }}</p>
                            </div>
                            <span id="statut-{{ rdv.id }}"
                                  style="font-size:0.75rem; font-weight:700; padding:0.25rem 0.5rem; border-radius:0.375rem; border:1px solid;
                                  {% if rdv.statut == 'Confirmé' %}background-color:#dcfce7;color:#15803d;border-color:#bbf7d0;
                                  {% elseif rdv.statut == 'Annulé' %}background-color:#fee2e2;color:#b91c1c;border-color:#fecaca;
                                  {% else %}background-color:#ffedd5;color:#c2410c;border-color:#fed7aa;{% endif %}">
                                {% if rdv.statut == 'Confirmé' %}<i class="fa-regular fa-circle-check mr-1"></i> Confirmé
                                {% elseif rdv.statut == 'Annulé' %}<i class="fa-regular fa-circle-xmark mr-1"></i> Annulé
                                {% else %}<i class="fa-regular fa-clock mr-1"></i> En attente{% endif %}
                            </span>
                        </div>
                        <div class="mt-3 flex items-center gap-4 text-sm text-slate-500">
                            <span class="flex items-center gap-1"><i class="fa-regular fa-clock"></i> {{ rdv.hdebut|date('H:i') }} - {{ rdv.hfin|date('H:i') }}</span>
                            {% if rdv.message %}<span class="flex items-center gap-1"><i class="fa-solid fa-comment"></i> {{ rdv.message }}</span>{% endif %}
                        </div>
                    </div>
                    <div class="flex gap-2 w-full sm:w-auto mt-2 sm:mt-0">
                        <button onclick="openEditRdvModal({{ rdv.id }})" class="flex-1 sm:flex-none border border-slate-200 text-slate-600 p-2 rounded-lg hover:bg-slate-50 transition text-center" title="Modifier">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <a href="{{ path('showOne', { id: rdv.id }) }}" class="flex-1 sm:flex-none border border-slate-200 text-blue-500 p-2 rounded-lg hover:bg-blue-50 transition text-center" title="Détails">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <button onclick="openDeleteModal({{ rdv.id }}, '{{ csrf_token('delete' ~ rdv.id) }}')" class="flex-1 sm:flex-none border border-red-200 text-red-600 p-2 rounded-lg hover:bg-red-50 transition text-center" title="Supprimer">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                {% else %}
                <p class="text-slate-500 text-center py-8">Aucun rendez-vous pour le moment.</p>
                {% endfor %}
            </div>

            {# Message "aucun résultat" pour les onglets #}
            <div id="emptyTabMsg" class="hidden text-center py-10 text-slate-400">
                <i class="fa-solid fa-calendar-xmark text-4xl mb-3 block opacity-40"></i>
                <p class="font-semibold" id="emptyTabText">Aucun rendez-vous dans cet onglet.</p>
            </div>

        </div>

        {# ===== COLONNE DROITE ===== #}
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h4 class="font-bold text-slate-800 text-sm" id="sideCalMonthTitle">—</h4>
                    <div class="flex gap-1">
                        <button onclick="sideCalChangeMonth(-1)" class="w-7 h-7 rounded-lg border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition text-slate-500">
                            <i class="fa-solid fa-chevron-left" style="font-size:0.6rem;"></i>
                        </button>
                        <button onclick="sideCalChangeMonth(1)" class="w-7 h-7 rounded-lg border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition text-slate-500">
                            <i class="fa-solid fa-chevron-right" style="font-size:0.6rem;"></i>
                        </button>
                    </div>
                </div>
                <div class="grid grid-cols-7 gap-0.5 text-center mb-1">
                    <span class="text-slate-400 text-xs font-semibold py-1">L</span>
                    <span class="text-slate-400 text-xs font-semibold py-1">M</span>
                    <span class="text-slate-400 text-xs font-semibold py-1">M</span>
                    <span class="text-slate-400 text-xs font-semibold py-1">J</span>
                    <span class="text-slate-400 text-xs font-semibold py-1">V</span>
                    <span class="text-orange-400 text-xs font-semibold py-1">S</span>
                    <span class="text-red-400 text-xs font-semibold py-1">D</span>
                </div>
                <div id="sideCalGrid" class="grid grid-cols-7 gap-0.5 text-center"></div>
                <p class="text-xs text-slate-400 text-center mt-3">
                    <i class="fa-regular fa-hand-pointer mr-1"></i> Cliquez sur une date pour prendre RDV
                </p>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <div class="flex justify-between items-center mb-4">
                    <h4 class="font-bold text-slate-800">Mes Médecins</h4>
                    <button onclick="toggleMedecins()" id="voirToutBtn" class="text-blue-600 text-xs font-bold hover:underline">Voir tout</button>
                </div>
                <div id="medecinsList" class="space-y-4 overflow-hidden transition-all duration-500" style="max-height: 160px;">
                    <div class="flex items-center gap-3 group cursor-pointer">
                        <div class="relative">
                            <img src="https://ui-avatars.com/api/?name=Sarah+Amrani&background=random" class="w-10 h-10 rounded-full">
                            <div class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 rounded-full border-2 border-white"></div>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 transition">Dr. S. Amrani</p>
                            <p class="text-xs text-slate-500">Cardiologue</p>
                        </div>
                        <button class="w-8 h-8 rounded-full bg-slate-50 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition">
                            <i class="fa-solid fa-calendar-plus text-xs"></i>
                        </button>
                    </div>
                    <div class="flex items-center gap-3 group cursor-pointer">
                        <img src="https://ui-avatars.com/api/?name=Mohamed+Kallel&background=random" class="w-10 h-10 rounded-full grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition">
                        <div class="flex-1">
                            <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 transition">Dr. M. Kallel</p>
                            <p class="text-xs text-slate-500">Ophtalmo</p>
                        </div>
                        <button class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-blue-600 hover:text-white transition">
                            <i class="fa-solid fa-calendar-plus text-xs"></i>
                        </button>
                    </div>
                    <div class="flex items-center gap-3 group cursor-pointer">
                        <img src="https://ui-avatars.com/api/?name=Ali+Zouhaier&background=random" class="w-10 h-10 rounded-full grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition">
                        <div class="flex-1">
                            <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 transition">Dr. A. Zouhaier</p>
                            <p class="text-xs text-slate-500">Neurologie</p>
                        </div>
                        <button class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-blue-600 hover:text-white transition">
                            <i class="fa-solid fa-calendar-plus text-xs"></i>
                        </button>
                    </div>
                    <div class="flex items-center gap-3 group cursor-pointer">
                        <img src="https://ui-avatars.com/api/?name=Fatma+Zouari&background=random" class="w-10 h-10 rounded-full grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition">
                        <div class="flex-1">
                            <p class="text-sm font-bold text-slate-800 group-hover:text-blue-600 transition">Dr. F. Zouari</p>
                            <p class="text-xs text-slate-500">Dermatologie</p>
                        </div>
                        <button class="w-8 h-8 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-blue-600 hover:text-white transition">
                            <i class="fa-solid fa-calendar-plus text-xs"></i>
                        </button>
                    </div>
                </div>
                <button onclick="openSpecialisteModal()"
                    class="w-full mt-6 py-2 border border-dashed border-slate-300 text-slate-500 rounded-xl text-sm font-medium hover:border-blue-400 hover:text-blue-600 transition flex items-center justify-center gap-2">
                    <i class="fa-solid fa-magnifying-glass"></i> Trouver un spécialiste
                </button>
            </div>
        </div>

    </div>
</div>

<!-- Modal Suppression -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div onclick="closeDeleteModal()" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 p-8 transform transition-all scale-95 opacity-0" id="deleteCard">
        <div class="text-center">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-trash text-red-600 text-2xl"></i>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">Supprimer ce rendez-vous ?</h3>
            <p class="text-slate-500 mb-6">Cette action est irréversible.</p>
            <form id="deleteForm" method="POST">
                <input type="hidden" name="_token" id="deleteToken">
                <div class="flex gap-3">
                    <button type="button" onclick="closeDeleteModal()" class="flex-1 px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-xl transition">Annuler</button>
                    <button type="submit" class="flex-1 px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl transition shadow-lg">Supprimer</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ===== MODAL TROUVER UN SPECIALISTE ===== #}
<div id="specialisteModal" class="fixed inset-0 z-50 {{ searched ? '' : 'hidden' }} flex items-center justify-center">
    <div onclick="closeSpecialisteModal()" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 p-8 max-h-[90vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-slate-800"><i class="fa-solid fa-magnifying-glass text-blue-600 mr-2"></i>Trouver un Spécialiste</h3>
            <button onclick="closeSpecialisteModal()" class="text-slate-400 hover:text-slate-700 transition"><i class="fa-solid fa-xmark text-xl"></i></button>
        </div>
        <form method="GET" action="{{ path('showAllRdvfront') }}">
            <div class="mb-4">
                <p class="text-sm font-semibold text-slate-600 mb-2">Spécialité</p>
                <div class="flex flex-wrap gap-2">
                    {% set specialites = ['Cardiologie', 'Ophtalmologie', 'Neurologie', 'Dermatologie', 'Pédiatrie', 'Gynécologie'] %}
                    {% for sp in specialites %}
                    <button type="button" onclick="selectSpecialite('{{ sp }}')"
                        id="tag-{{ sp|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ô': 'o'}) }}"
                        class="specialite-tag px-3 py-1.5 rounded-full text-sm font-medium border border-slate-200 text-slate-600 hover:border-blue-400 hover:text-blue-600 hover:bg-blue-50 transition {{ specialite == sp ? 'bg-blue-600 text-white border-blue-600' : '' }}">
                        {{ sp }}
                    </button>
                    {% endfor %}
                </div>
                <input type="hidden" name="specialite" id="specialiteInput" value="{{ specialite }}">
            </div>
            <div class="mb-4">
                <label class="text-sm font-semibold text-slate-600 mb-1 block">Nom du médecin</label>
                <input type="text" name="nom" value="{{ nom }}" placeholder="Ex: Amrani, Kallel..." class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-blue-400 transition">
            </div>
            <div class="mb-6">
                <label class="text-sm font-semibold text-slate-600 mb-1 block">Type de consultation</label>
                <select name="type" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-blue-400 transition">
                    <option value="">Tous</option>
                    <option value="En ligne" {{ type == 'En ligne' ? 'selected' : '' }}>En ligne</option>
                    <option value="Présentiel" {{ type == 'Présentiel' ? 'selected' : '' }}>Présentiel</option>
                    <option value="Les deux" {{ type == 'Les deux' ? 'selected' : '' }}>Les deux</option>
                </select>
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition shadow-lg flex items-center justify-center gap-2">
                <i class="fa-solid fa-magnifying-glass"></i> Rechercher
            </button>
        </form>
        {% if searched %}
        <div class="mt-6 border-t border-slate-100 pt-6">
            <p class="text-sm text-slate-500 mb-4 font-medium">{{ medecins|length }} résultat{{ medecins|length > 1 ? 's' : '' }} trouvé{{ medecins|length > 1 ? 's' : '' }}</p>
            {% if medecins is empty %}
                <div class="text-center py-8 text-slate-400">
                    <i class="fa-solid fa-user-doctor text-4xl mb-3 block"></i>
                    <p>Aucun médecin trouvé pour ces critères.</p>
                </div>
            {% else %}
                <div class="space-y-3">
                {% for medecin in medecins %}
                <div class="flex items-center gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100 hover:border-blue-200 transition">
                    <div class="w-12 h-12 rounded-full bg-blue-100 text-blue-700 font-bold text-sm flex items-center justify-center flex-shrink-0">
                        {{ medecin.prenom|first|upper }}{{ medecin.nom|first|upper }}
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-slate-800">Dr. {{ medecin.prenom }} {{ medecin.nom }}</p>
                        <p class="text-xs text-slate-500">{{ medecin.specialite }} · {{ medecin.type }}</p>
                    </div>
                    <span style="font-size:0.75rem;font-weight:700;padding:0.25rem 0.5rem;border-radius:9999px;{{ medecin.disponible ? 'background-color:#dcfce7;color:#15803d;' : 'background-color:#fee2e2;color:#b91c1c;' }}">
                        {{ medecin.disponible ? '🟢 Disponible' : '🔴 Complet' }}
                    </span>
                    {% if medecin.disponible %}
                    <a href="{{ path('AjouterRdv') }}" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-3 py-2 rounded-lg transition flex-shrink-0">+ RDV</a>
                    {% endif %}
                </div>
                {% endfor %}
                </div>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

<script>
// ====================================================
// DATE DU JOUR (format YYYY-MM-DD pour comparaison)
// ====================================================
const TODAY_STR = '{{ "now"|date("Y-m-d") }}';
const today     = new Date(TODAY_STR + 'T00:00:00');

// ====================================================
// FILTRES ONGLETS — 100% côté client, par data-date
// ====================================================
let activeTab = 'avenir'; // onglet actif par défaut

function filterTab(tab) {
    activeTab = tab;

    // Reset style de tous les onglets boutons
    ['avenir', 'passes', 'annules'].forEach(t => {
        document.getElementById('tab-' + t).className =
            'text-slate-500 font-medium hover:text-slate-800 pb-3 px-1 transition';
    });
    // Activer l'onglet sélectionné
    document.getElementById('tab-' + tab).className =
        'text-blue-600 font-bold border-b-2 border-blue-600 pb-3 px-1 transition';

    const cards    = document.querySelectorAll('.rdv-card');
    const emptyMsg = document.getElementById('emptyTabMsg');
    const emptyTxt = document.getElementById('emptyTabText');
    let   visible  = 0;

    cards.forEach(card => {
        const rdvDate  = new Date(card.dataset.date + 'T00:00:00');
        const statut   = card.dataset.statut;
        const isPast   = rdvDate < today;   // strictement avant aujourd'hui
        const isFuture = rdvDate >= today;  // aujourd'hui inclus = à venir
        const isAnnule = statut === 'Annulé';

        let show = false;

        if (tab === 'avenir') {
            // Aujourd'hui + futur, pas annulé
            show = isFuture && !isAnnule;
        } else if (tab === 'passes') {
            // Strictement avant aujourd'hui (non annulé — les annulés ont leur propre onglet)
            show = isPast && !isAnnule;
        } else if (tab === 'annules') {
            // Tous les annulés, passés ou futurs
            show = isAnnule;
        }

        card.style.display = show ? '' : 'none';
        if (show) visible++;
    });

    // Message vide
    if (visible === 0) {
        const messages = {
            avenir:  'Aucun rendez-vous à venir.',
            passes:  'Aucun rendez-vous passé.',
            annules: 'Aucun rendez-vous annulé.',
        };
        emptyTxt.textContent = messages[tab] || '';
        emptyMsg.classList.remove('hidden');
    } else {
        emptyMsg.classList.add('hidden');
    }
}

