            banner.innerHTML=`<div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;"><div style="display:flex;align-items:center;gap:1rem;"><i class="fa-solid fa-bell" style="font-size:1.25rem;"></i><p style="font-weight:700;">${top.message}</p></div><button onclick="fermerRappel()" style="background:rgba(255,255,255,0.2);border:2px solid white;color:white;padding:0.4rem 0.8rem;border-radius:0.5rem;font-weight:700;cursor:pointer;">✓ Fermer</button></div>`;
        } else {
            banner.style.cssText='display:block;position:fixed;top:0;left:0;right:0;z-index:9999;background:linear-gradient(135deg,#3b82f6,#2563eb);color:white;padding:0.75rem 2rem;box-shadow:0 4px 15px rgba(59,130,246,0.4);';
            banner.innerHTML=`<div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;"><div style="display:flex;align-items:center;gap:1rem;"><i class="fa-solid fa-calendar-check" style="font-size:1.25rem;"></i><p style="font-weight:700;">${top.message}</p></div><button onclick="fermerRappel()" style="background:rgba(255,255,255,0.2);border:2px solid white;color:white;padding:0.4rem 0.8rem;border-radius:0.5rem;font-weight:700;cursor:pointer;">✓ Fermer</button></div>`;
        }
    } catch(e){ console.error('Erreur rappels:',e); }
}
