// ====================================================
// RECHERCHE AJAX
// ====================================================
const searchInput     = document.getElementById('searchRdv');
const searchBox       = document.getElementById('searchBox');
const searchIcon      = document.getElementById('searchIcon');
const searchSpinner   = document.getElementById('searchSpinner');
const clearBtn        = document.getElementById('clearSearch');
const dropdown        = document.getElementById('searchDropdown');
const dropdownContent = document.getElementById('searchDropdownContent');
let debounceTimer;

searchInput.addEventListener('focus', () => {
    searchBox.style.width='300px'; searchBox.style.borderColor='#3b82f6';
    searchBox.style.boxShadow='0 4px 20px rgba(59,130,246,0.15)'; searchIcon.style.color='#3b82f6';
});
searchInput.addEventListener('blur', () => {
    setTimeout(() => {
        dropdown.style.display='none';
        if(searchInput.value.trim()===''){
            searchBox.style.width='180px'; searchBox.style.borderColor='#e2e8f0';
            searchBox.style.boxShadow='none'; searchIcon.style.color='#94a3b8';
        }
    }, 200);
});
searchInput.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    const query = this.value.trim();
    clearBtn.style.display = query.length > 0 ? 'block' : 'none';
    if(query.length < 1){
        dropdown.style.display='none';
        // Rétablir le filtre d'onglet actif
        filterTab(activeTab);
        return;
    }
    searchSpinner.style.display='block';
    debounceTimer=setTimeout(()=>{
        fetch(`/rdv/search?q=${encodeURIComponent(query)}`)
        .then(res=>res.json())
        .then(rdvs=>{
            searchSpinner.style.display='none';
            renderDropdown(rdvs,query);
            // Afficher tous les résultats sans filtre d'onglet pendant la recherche
            const cards=document.querySelectorAll('.rdv-card');
            cards.forEach(c=>{
                const h3=c.querySelector('h3');
                const motif=c.querySelector('p.text-slate-500');
                const txt=(h3?h3.textContent:'')+(motif?motif.textContent:'');
                c.style.display=txt.toLowerCase().includes(query.toLowerCase())?'':'none';
            });
            document.getElementById('emptyTabMsg').classList.add('hidden');
        })
        .catch(err=>{searchSpinner.style.display='none';console.error(err);});
    },300);
});
function clearSearchInput(){
    searchInput.value=''; clearBtn.style.display='none'; dropdown.style.display='none';
    searchBox.style.width='180px'; searchBox.style.borderColor='#e2e8f0';
    searchBox.style.boxShadow='none'; searchIcon.style.color='#94a3b8';
    filterTab(activeTab); searchInput.focus();
}
function highlight(text,q){
    if(!text)return'';
    const regex=new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
    return text.replace(regex,`<mark style="background:#dbeafe;color:#1d4ed8;border-radius:3px;padding:0 2px;font-weight:700;">$1</mark>`);
}
function renderDropdown(rdvs,query){
    if(rdvs.length===0){
        dropdownContent.innerHTML=`<div style="padding:14px 16px;text-align:center;color:#94a3b8;font-size:0.875rem;"><i class="fa-solid fa-face-frown" style="margin-right:6px;"></i>Aucun résultat pour "<strong style="color:#64748b;">${query}</strong>"</div>`;
        dropdown.style.display='block'; return;
    }
    const header=`<div style="padding:8px 16px;font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;border-bottom:1px solid #f1f5f9;background:#f8fafc;"><i class="fa-solid fa-list" style="margin-right:6px;"></i>${rdvs.length} résultat${rdvs.length>1?'s':''}</div>`;
    const items=rdvs.slice(0,5).map(rdv=>{
        const bg=rdv.statut==='Confirmé'?'#dcfce7':rdv.statut==='Annulé'?'#fee2e2':'#ffedd5';
        const color=rdv.statut==='Confirmé'?'#15803d':rdv.statut==='Annulé'?'#b91c1c':'#c2410c';
        return `<div style="display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;border-bottom:1px solid #f8fafc;transition:background 0.15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='white'">
            <div style="width:34px;height:34px;border-radius:50%;background:#dbeafe;color:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.8rem;flex-shrink:0;">${(rdv.medecin||'?').charAt(0).toUpperCase()}</div>
            <div style="flex:1;min-width:0;"><p style="font-weight:600;color:#1e293b;font-size:0.875rem;margin:0;">${highlight(rdv.medecin,query)}</p>
            <p style="color:#94a3b8;font-size:0.72rem;margin:2px 0 0;">${highlight(rdv.motif||'',query)}</p></div>
            <span style="font-size:0.68rem;font-weight:700;padding:2px 8px;border-radius:9999px;background:${bg};color:${color};flex-shrink:0;">${rdv.statut}</span>
        </div>`;
    }).join('');
    dropdownContent.innerHTML=header+items;
    dropdown.style.display='block';
}
</script>

{% include 'rdv/front/modal_calendrier.html.twig' %}

<script>
// ====================================================
// MINI CALENDRIER LATÉRAL
// ====================================================
const MOIS_SIDE=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
let sideCalDate=new Date();

function sideCalRender(){
    const year=sideCalDate.getFullYear(), month=sideCalDate.getMonth();
    const todaySide=new Date(); todaySide.setHours(0,0,0,0);
    document.getElementById('sideCalMonthTitle').textContent=MOIS_SIDE[month]+' '+year;
    let startDow=new Date(year,month,1).getDay();
    startDow=startDow===0?6:startDow-1;
    const lastDay=new Date(year,month+1,0).getDate();
    const grid=document.getElementById('sideCalGrid');
    grid.innerHTML='';
    for(let i=0;i<startDow;i++){const e=document.createElement('div');e.style.cssText='padding:6px 0;';grid.appendChild(e);}
    for(let d=1;d<=lastDay;d++){
        const date=new Date(year,month,d), dow=date.getDay(), past=date<todaySide, isToday=date.getTime()===todaySide.getTime();
        const el=document.createElement('div');
        el.textContent=d;
        el.style.cssText='padding:6px 0;border-radius:8px;font-size:0.75rem;font-weight:600;transition:all 0.15s;cursor:pointer;';
        if(isToday){el.style.background='#2563eb';el.style.color='white';}
        else if(past){el.style.color='#cbd5e1';el.style.cursor='default';el.style.textDecoration='line-through';}
        else if(dow===0){el.style.color='#fca5a5';el.style.cursor='not-allowed';el.title='Fermé le dimanche';}
        else if(dow===6){el.style.color='#fb923c';el.addEventListener('mouseover',()=>{el.style.background='#fff7ed';});el.addEventListener('mouseout',()=>{el.style.background='transparent';});}
        else{el.style.color='#475569';el.addEventListener('mouseover',()=>{el.style.background='#eff6ff';el.style.color='#2563eb';});el.addEventListener('mouseout',()=>{el.style.background='transparent';el.style.color='#475569';});}
        if(!past&&dow!==0){el.addEventListener('click',()=>{calState.currentDate=new Date(year,month,1);calState.selectedDate=new Date(year,month,d);openCalModal();});}
        grid.appendChild(el);
    }
}
function sideCalChangeMonth(delta){sideCalDate=new Date(sideCalDate.getFullYear(),sideCalDate.getMonth()+delta,1);sideCalRender();}
sideCalRender();
</script>

