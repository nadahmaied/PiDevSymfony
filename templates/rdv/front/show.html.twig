// ====================================================
// API STATUTS (polling auto)
// ====================================================
async function fetchStatuts() {
    try {
        const data = await (await fetch('/api/rdv/statuts')).json();
        data.forEach(rdv => {
            const el = document.getElementById('statut-'+rdv.id);
            if (!el) return;
            if (rdv.statut==='Confirmé'){el.style.backgroundColor='#dcfce7';el.style.color='#15803d';el.style.borderColor='#bbf7d0';el.innerHTML='<i class="fa-regular fa-circle-check" style="margin-right:0.25rem;"></i> Confirmé';}
            else if(rdv.statut==='Annulé'){el.style.backgroundColor='#fee2e2';el.style.color='#b91c1c';el.style.borderColor='#fecaca';el.innerHTML='<i class="fa-regular fa-circle-xmark" style="margin-right:0.25rem;"></i> Annulé';}
            else{el.style.backgroundColor='#ffedd5';el.style.color='#c2410c';el.style.borderColor='#fed7aa';el.innerHTML='<i class="fa-regular fa-clock" style="margin-right:0.25rem;"></i> En attente';}
        });
        // Re-filtrer après mise à jour des statuts (un annulé peut changer d'onglet)
        data.forEach(rdv => {
            const card = document.querySelector(`.rdv-card [id="statut-${rdv.id}"]`)?.closest('.rdv-card');
            if (card) card.dataset.statut = rdv.statut;
        });
        filterTab(activeTab);
    } catch(e){ console.error('Erreur statuts:',e); }
}
fetchStatuts(); setInterval(fetchStatuts, 10000);

