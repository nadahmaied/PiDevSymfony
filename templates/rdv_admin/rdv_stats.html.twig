{% extends 'rdv_admin/base.html.twig' %}

{% block title %}Statistiques RDV - Admin VitalTech{% endblock %}
{% block page_header %}Statistiques des Rendez-vous{% endblock %}
{% block page_subtitle %}Analyse globale et indicateurs de performance{% endblock %}

{% block stylesheets %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
{% endblock %}

{% block header_actions %}
    <a href="{{ path('admin_rdv_index') }}"
       class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-2.5 rounded-xl shadow transition text-sm">
        <i class="fa-solid fa-list-check"></i> Tous les RDVs
    </a>
{% endblock %}

{% block body %}

{# ── KPIs ── #}
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8" id="kpiGrid">
    <div class="kpi-card rounded-2xl p-5 text-white shadow-lg md:col-span-1">
        <div class="flex items-center justify-between mb-2">
            <p class="text-white/80 text-xs font-bold uppercase tracking-wide">Total RDVs</p>
            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-calendar-check text-xs"></i>
            </div>
        </div>
        <p class="text-5xl font-black">{{ total }}</p>
        <p class="text-white/70 text-xs mt-1">Tous les rendez-vous</p>
    </div>

    <div class="kpi-card rounded-2xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-2">
            <p class="text-white/80 text-xs font-bold uppercase">Confirmés</p>
            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-check-circle text-xs"></i>
            </div>
        </div>
        <p class="text-5xl font-black">{{ confirmes }}</p>
        <p class="text-white/70 text-xs mt-1">{{ tauxConfirmation }}% du total</p>
    </div>

    <div class="kpi-card rounded-2xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-2">
            <p class="text-white/80 text-xs font-bold uppercase">En attente</p>
            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-clock text-xs"></i>
            </div>
        </div>
        <p class="text-5xl font-black">{{ enAttente }}</p>
        <p class="text-white/70 text-xs mt-1">À traiter</p>
    </div>

    <div class="kpi-card rounded-2xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-2">
            <p class="text-white/80 text-xs font-bold uppercase">Annulés</p>
            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-ban text-xs"></i>
            </div>
        </div>
        <p class="text-5xl font-black">{{ annules }}</p>
        <p class="text-white/70 text-xs mt-1">{{ tauxAnnulation }}% du total</p>
    </div>

    <div class="kpi-card rounded-2xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-2">
            <p class="text-white/80 text-xs font-bold uppercase">Aujourd'hui</p>
            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-calendar-day text-xs"></i>
            </div>
        </div>
        <p class="text-5xl font-black">{{ aujourdhui }}</p>
        <p class="text-white/70 text-xs mt-1">RDV du jour</p>
    </div>
</div>

{# ── Taux de confirmation bar ── #}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h3 class="font-bold text-gray-800">Taux de confirmation global</h3>
            <p class="text-xs text-gray-400">Répartition des statuts sur l'ensemble des RDVs</p>
        </div>
        <span class="text-2xl font-black text-green-600">{{ tauxConfirmation }}%</span>
    </div>
    <div class="flex h-4 rounded-full overflow-hidden gap-0.5">
        {% if total > 0 %}
            <div class="bg-green-500 rounded-l-full transition-all" style="width: {{ tauxConfirmation }}%" title="Confirmés"></div>
            <div class="bg-orange-400 transition-all" style="width: {{ total > 0 ? (enAttente / total * 100)|round : 0 }}%" title="En attente"></div>
            <div class="bg-red-400 rounded-r-full transition-all" style="width: {{ tauxAnnulation }}%" title="Annulés"></div>
        {% else %}
            <div class="bg-gray-200 w-full rounded-full"></div>
        {% endif %}
    </div>
    <div class="flex gap-6 mt-3">
        <div class="flex items-center gap-2 text-xs text-gray-500">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 inline-block"></span> Confirmés ({{ confirmes }})
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-500">
            <span class="w-2.5 h-2.5 rounded-full bg-orange-400 inline-block"></span> En attente ({{ enAttente }})
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-500">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400 inline-block"></span> Annulés ({{ annules }})
        </div>
    </div>
</div>

{# ── Graphiques ligne 1 ── #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h3 class="font-bold text-gray-800 mb-1 text-sm">Répartition par statut</h3>
        <p class="text-xs text-gray-400 mb-4">Distribution globale</p>
        <div class="flex items-center justify-center">
            <div style="width: 200px; height: 200px;">
                <canvas id="donutStatuts"></canvas>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 md:col-span-2">
        <h3 class="font-bold text-gray-800 mb-1 text-sm">RDVs par médecin</h3>
        <p class="text-xs text-gray-400 mb-4">Nombre de rendez-vous par praticien</p>
        <canvas id="barMedecin" height="180"></canvas>
    </div>
</div>

{# ── Graphiques ligne 2 ── #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 md:col-span-2">
        <h3 class="font-bold text-gray-800 mb-1 text-sm">Évolution mensuelle</h3>
        <p class="text-xs text-gray-400 mb-4">Nombre de RDVs sur les 12 derniers mois</p>
        <canvas id="lineMois" height="120"></canvas>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h3 class="font-bold text-gray-800 mb-1 text-sm">Par spécialité</h3>
        <p class="text-xs text-gray-400 mb-4">Répartition par spécialité</p>
        <div class="flex items-center justify-center">
            <div style="width: 200px; height: 200px;">
                <canvas id="donutSpecialite"></canvas>
            </div>
        </div>
    </div>
</div>

{# ── Top motifs ── #}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <h3 class="font-bold text-gray-800 mb-1 text-sm">Top 5 motifs de consultation</h3>
    <p class="text-xs text-gray-400 mb-5">Les motifs les plus fréquents</p>
    <div class="space-y-4">
        {% set maxMotif = rdvParMotif|first %}
        {% for motif, count in rdvParMotif %}
        <div class="flex items-center gap-4">
            <span class="w-36 text-xs text-gray-600 font-semibold truncate">{{ motif }}</span>
            <div class="flex-1 bg-gray-100 rounded-full h-2.5 overflow-hidden">
                <div class="h-2.5 rounded-full motif-bar"
                     style="width: {{ maxMotif > 0 ? (count / maxMotif * 100)|round : 0 }}%"></div>
            </div>
            <span class="text-xs font-black text-gray-700 w-6 text-right">{{ count }}</span>
        </div>
        {% else %}
        <p class="text-gray-400 text-sm text-center py-4">Aucune donnée disponible</p>
        {% endfor %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// ══════════════════════════════════════
// PALETTES — change à chaque refresh
// ══════════════════════════════════════
const PALETTES = [
    // Bleu / vert
    ['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#84cc16'],
    // Violet / rose
    ['#8b5cf6','#ec4899','#06b6d4','#f97316','#14b8a6','#a855f7','#f43f5e','#0ea5e9'],
    // Cyan / teal
    ['#06b6d4','#14b8a6','#3b82f6','#a855f7','#f59e0b','#10b981','#ef4444','#f97316'],
    // Warm
    ['#f97316','#eab308','#ef4444','#ec4899','#8b5cf6','#06b6d4','#10b981','#3b82f6'],
    // Indigo / émeraude
    ['#6366f1','#10b981','#f59e0b','#e11d48','#0ea5e9','#7c3aed','#059669','#dc2626'],
];

// KPI gradients — une palette par refresh
const KPI_GRADIENTS = [
    ['from-blue-600 to-blue-700',   'shadow-blue-200'],
    ['from-green-500 to-emerald-600','shadow-green-200'],
    ['from-orange-500 to-amber-500', 'shadow-orange-200'],
    ['from-red-500 to-rose-600',     'shadow-red-200'],
    ['from-sky-500 to-cyan-600',     'shadow-sky-200'],
    ['from-violet-600 to-purple-700','shadow-violet-200'],
    ['from-pink-500 to-rose-500',    'shadow-pink-200'],
    ['from-teal-500 to-cyan-600',    'shadow-teal-200'],
    ['from-indigo-600 to-violet-700','shadow-indigo-200'],
    ['from-amber-500 to-yellow-500', 'shadow-amber-200'],
];

function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
}

// Choisir une palette aléatoire
const COLORS = shuffle(PALETTES[Math.floor(Math.random() * PALETTES.length)]);

// ── Appliquer couleurs aléatoires aux cartes KPI ──
const kpiCards = document.querySelectorAll('.kpi-card');
const shuffledGradients = shuffle(KPI_GRADIENTS);
kpiCards.forEach((card, i) => {
    const [grad, shadow] = shuffledGradients[i % shuffledGradients.length];
    card.style.background = '';
    // Convertir les classes Tailwind en CSS inline pour éviter les conflits
    const gradMap = {
        'from-blue-600 to-blue-700':    'linear-gradient(135deg, #2563eb, #1d4ed8)',
        'from-green-500 to-emerald-600':'linear-gradient(135deg, #22c55e, #059669)',
        'from-orange-500 to-amber-500': 'linear-gradient(135deg, #f97316, #f59e0b)',
        'from-red-500 to-rose-600':     'linear-gradient(135deg, #ef4444, #e11d48)',
        'from-sky-500 to-cyan-600':     'linear-gradient(135deg, #0ea5e9, #0891b2)',
        'from-violet-600 to-purple-700':'linear-gradient(135deg, #7c3aed, #6d28d9)',
        'from-pink-500 to-rose-500':    'linear-gradient(135deg, #ec4899, #f43f5e)',
        'from-teal-500 to-cyan-600':    'linear-gradient(135deg, #14b8a6, #0891b2)',
        'from-indigo-600 to-violet-700':'linear-gradient(135deg, #4f46e5, #6d28d9)',
        'from-amber-500 to-yellow-500': 'linear-gradient(135deg, #f59e0b, #eab308)',
    };
    card.style.background = gradMap[grad] || gradMap['from-blue-600 to-blue-700'];
});

// ── Couleur aléatoire pour les barres de motifs ──
const motifColor = COLORS[0];
document.querySelectorAll('.motif-bar').forEach((bar, i) => {
    bar.style.background = `linear-gradient(to right, ${COLORS[i % COLORS.length]}, ${COLORS[(i+1) % COLORS.length]})`;
});

// ── Donut statuts ──
new Chart(document.getElementById('donutStatuts'), {
    type: 'doughnut',
    data: {
        labels: ['Confirmés', 'En attente', 'Annulés'],
        datasets: [{
            data: [{{ confirmes }}, {{ enAttente }}, {{ annules }}],
            backgroundColor: [COLORS[1], COLORS[2], COLORS[3]],
            borderWidth: 4,
            borderColor: '#fff',
            hoverOffset: 6,
        }]
    },
    options: {
        cutout: '68%',
        plugins: { legend: { display: false } }
    }
});

// ── Bar médecin ──
new Chart(document.getElementById('barMedecin'), {
    type: 'bar',
    data: {
        labels: {{ rdvParMedecin|keys|json_encode|raw }},
        datasets: [{
            label: 'Rendez-vous',
            data: [{% for k, v in rdvParMedecin %}{{ v }}{% if not loop.last %},{% endif %}{% endfor %}],
            backgroundColor: COLORS,
            borderRadius: 10,
            borderSkipped: false,
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { stepSize: 1, font: { size: 11 } } },
            x: { grid: { display: false }, ticks: { font: { size: 11 } } }
        }
    }
});

// ── Line mois ──
new Chart(document.getElementById('lineMois'), {
    type: 'line',
    data: {
        labels: {{ rdvParMois|keys|json_encode|raw }},
        datasets: [{
            label: 'RDVs',
            data: [{% for k, v in rdvParMois %}{{ v }}{% if not loop.last %},{% endif %}{% endfor %}],
            borderColor: COLORS[0],
            backgroundColor: COLORS[0] + '18',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: COLORS[0],
            pointRadius: 5,
            pointHoverRadius: 7,
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { stepSize: 1 } },
            x: { grid: { display: false }, ticks: { font: { size: 10 } } }
        }
    }
});

// ── Donut spécialité ──
new Chart(document.getElementById('donutSpecialite'), {
    type: 'doughnut',
    data: {
        labels: {{ rdvParSpecialite|keys|json_encode|raw }},
        datasets: [{
            data: [{% for k, v in rdvParSpecialite %}{{ v }}{% if not loop.last %},{% endif %}{% endfor %}],
            backgroundColor: COLORS,
            borderWidth: 4,
            borderColor: '#fff',
        }]
    },
    options: {
        cutout: '55%',
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 10, padding: 8 } }
        }
    }
});
</script>
{% endblock %}
