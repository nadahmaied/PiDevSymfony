<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin RDV - VitalTech{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 font-sans">
<div class="flex h-screen overflow-hidden">

    {# ── Sidebar Admin RDV ── #}
    <aside class="w-64 bg-slate-900 text-white flex flex-col flex-shrink-0">

        {# Logo #}
        <div class="p-6 flex items-center gap-3 border-b border-slate-800">
            <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
                <i class="fa-solid fa-calendar-heart text-white text-sm"></i>
            </div>
            <div>
                <p class="font-black text-white text-sm tracking-wide">VITALTECH</p>
                <p class="text-slate-400 text-xs">Espace Administration</p>
            </div>
        </div>

        {# Navigation #}
        <nav class="flex-1 p-4 space-y-1 text-sm overflow-y-auto">

            <p class="text-xs font-bold text-slate-500 uppercase mb-2 pl-3 mt-2">Rendez-vous</p>

            <a href="{{ path('admin_rdv_index') }}"
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition
               {% if app.request.get('_route') == 'admin_rdv_index' %}
                   bg-blue-600 text-white shadow-lg shadow-blue-900/40
               {% else %}
                   text-slate-400 hover:bg-slate-800 hover:text-white
               {% endif %}">
                <i class="fa-solid fa-list-check w-5"></i> Tous les RDVs
            </a>

            <a href="{{ path('admin_rdv_stats') }}"
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition
               {% if app.request.get('_route') == 'admin_rdv_stats' %}
                   bg-purple-600 text-white shadow-lg shadow-purple-900/40
               {% else %}
                   text-slate-400 hover:bg-slate-800 hover:text-white
               {% endif %}">
                <i class="fa-solid fa-chart-pie w-5"></i> Statistiques
            </a>

            <a href="{{ path('admin_dispo_index') }}"
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition
               {% if app.request.get('_route') == 'admin_dispo_index' %}
                   bg-cyan-600 text-white shadow-lg shadow-cyan-900/40
               {% else %}
                   text-slate-400 hover:bg-slate-800 hover:text-white
               {% endif %}">
                <i class="fa-solid fa-calendar-days w-5"></i> Disponibilités
            </a>

            <p class="text-xs font-bold text-slate-500 uppercase mb-2 pl-3 mt-6">Système</p>

            <a href="{{ path('admin_user_index') }}"
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition text-slate-400 hover:bg-slate-800 hover:text-white">
                <i class="fa-solid fa-users-gear w-5"></i> Utilisateurs
            </a>

        </nav>

        {# Bas sidebar #}
        <div class="p-4 border-t border-slate-800 space-y-2">
            <div class="flex items-center gap-3 px-3 py-2">
                <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm">
                    {{ app.user ? app.user.prenom|slice(0,1)|upper : 'A' }}
                </div>
                <div class="text-xs">
                    <p class="text-white font-semibold">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Admin' }}</p>
                    <p class="text-slate-400">{{ app.user ? app.user.email : '' }}</p>
                </div>
            </div>
            <a href="{{ path('front_logout') }}"
               class="flex items-center justify-center gap-2 w-full px-4 py-2.5
                      bg-red-900/40 hover:bg-red-800 text-red-400 hover:text-white
                      font-semibold rounded-xl border border-red-800/50 transition text-sm">
                <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
            </a>
        </div>
    </aside>

    {# ── Main Content ── #}
    <main class="flex-1 flex flex-col overflow-hidden">

        {# Header #}
        <header class="bg-white border-b border-gray-200 py-4 px-8 flex justify-between items-center shadow-sm z-10">
            <div>
                <h1 class="text-xl font-bold text-gray-800">{% block page_header %}Administration{% endblock %}</h1>
                <p class="text-xs text-gray-500 mt-0.5">{% block page_subtitle %}Gestion des rendez-vous{% endblock %}</p>
            </div>
            <div class="flex items-center gap-3">
                {% block header_actions %}{% endblock %}
                <span class="bg-green-100 text-green-700 text-xs font-bold px-3 py-1 rounded-full border border-green-200">
                    <i class="fa-solid fa-circle text-green-500 text-xs mr-1"></i> Système Actif
                </span>
            </div>
        </header>

        {# Flash messages #}
        <div class="px-8 pt-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-3 p-4 rounded-xl border text-sm
                        {% if label == 'success' %}bg-green-50 text-green-700 border-green-200
                        {% elseif label == 'error' or label == 'danger' %}bg-red-50 text-red-700 border-red-200
                        {% else %}bg-blue-50 text-blue-700 border-blue-200{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# Page Content #}
        <div class="flex-1 overflow-y-auto p-8 pt-4">
            {% block body %}{% endblock %}
        </div>
    </main>
</div>
{% block javascripts %}{% endblock %}
</body>
</html>
