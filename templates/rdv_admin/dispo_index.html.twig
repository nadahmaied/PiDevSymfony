{% extends 'rdv_admin/base.html.twig' %}

{% block title %}Disponibilités - Admin VitalTech{% endblock %}
{% block page_header %}Disponibilités des Médecins{% endblock %}
{% block page_subtitle %}Vue globale des créneaux de tous les praticiens{% endblock %}

{% block header_actions %}
    <a href="{{ path('admin_rdv_index') }}"
       class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-2.5 rounded-xl shadow transition text-sm">
        <i class="fa-solid fa-list-check"></i> Tous les RDVs
    </a>
    <a href="{{ path('admin_rdv_stats') }}"
       class="inline-flex items-center gap-2 bg-purple-600 hover:bg-purple-700 text-white font-bold px-4 py-2.5 rounded-xl shadow transition text-sm">
        <i class="fa-solid fa-chart-pie"></i> Statistiques
    </a>
{% endblock %}

{% block body %}

{% if dispoParMedecin is empty %}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-16 text-center text-gray-400">
        <i class="fa-solid fa-calendar-xmark text-5xl mb-4 block opacity-30"></i>
        <p class="font-medium">Aucun médecin trouvé.</p>
    </div>
{% else %}

<div class="space-y-5">
{% for item in dispoParMedecin %}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

    {# ── En-tête médecin ── #}
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-slate-50 to-white">
        <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 text-white flex items-center justify-center font-black text-sm shadow-md shadow-blue-200">
                {{ item.medecin.prenom|slice(0,1)|upper }}{{ item.medecin.nom|slice(0,1)|upper }}
            </div>
            <div>
                <p class="font-bold text-gray-800">{{ item.nom }}</p>
                <div class="flex items-center gap-3 mt-0.5">
                    {% if item.medecin.specialite %}
                    <span class="text-xs text-gray-400">
                        <i class="fa-solid fa-stethoscope mr-1 text-blue-400"></i>{{ item.medecin.specialite }}
                    </span>
                    {% endif %}
                    {% if item.medecin.type %}
                    <span class="text-xs text-gray-400">
                        <i class="fa-solid fa-building-columns mr-1 text-slate-400"></i>{{ item.medecin.type }}
                    </span>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <span class="bg-blue-50 text-blue-700 text-xs font-bold px-3 py-1.5 rounded-full border border-blue-100">
                <i class="fa-solid fa-calendar mr-1"></i>{{ item.total }} créneau(x)
            </span>
            <a href="{{ path('showAlldispoBackDispo', {medecinId: item.medecin.id}) }}"
               class="text-xs text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1 hover:underline">
                Calendrier <i class="fa-solid fa-arrow-right text-xs"></i>
            </a>
        </div>
    </div>

    {# ── Liste disponibilités ── #}
    {% if item.dispos is empty %}
        <div class="px-6 py-8 text-center text-gray-400 text-sm">
            <i class="fa-regular fa-calendar text-2xl mb-2 block opacity-40"></i>
            Aucune disponibilité personnalisée enregistrée
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
                    <tr>
                        <th class="px-6 py-3">Date</th>
                        <th class="px-6 py-3">Heure début</th>
                        <th class="px-6 py-3">Heure fin</th>
                        <th class="px-6 py-3">Durée</th>
                        <th class="px-6 py-3">Statut</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                {% for dispo in item.dispos %}
                    <tr class="hover:bg-slate-50/50 transition">
                        <td class="px-6 py-3.5">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-xs">
                                    {{ dispo.dateDispo ? dispo.dateDispo|date('d') : '?' }}
                                </div>
                                <div>
                                    <p class="font-bold text-gray-800 text-xs">{{ dispo.dateDispo ? dispo.dateDispo|date('d/m/Y') : '—' }}</p>
                                    <p class="text-gray-400 text-xs">
                                        {{ dispo.dateDispo ? dispo.dateDispo|date('l')|replace({
                                            'Monday':'Lundi','Tuesday':'Mardi','Wednesday':'Mercredi',
                                            'Thursday':'Jeudi','Friday':'Vendredi','Saturday':'Samedi','Sunday':'Dimanche'
                                        }) : '' }}
                                    </p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-3.5">
                            <span class="inline-flex items-center gap-1.5 text-gray-700 font-semibold text-xs bg-gray-100 px-2.5 py-1 rounded-lg">
                                <i class="fa-regular fa-clock text-blue-400"></i>
                                {{ dispo.hdebut ? dispo.hdebut|date('H:i') : '—' }}
                            </span>
                        </td>
                        <td class="px-6 py-3.5">
                            <span class="inline-flex items-center gap-1.5 text-gray-700 font-semibold text-xs bg-gray-100 px-2.5 py-1 rounded-lg">
                                <i class="fa-regular fa-clock text-slate-400"></i>
                                {{ dispo.hFin ? dispo.hFin|date('H:i') : '—' }}
                            </span>
                        </td>
                        <td class="px-6 py-3.5">
                            <span class="text-xs font-bold text-gray-600">{{ dispo.nbrH }}h</span>
                        </td>
                        <td class="px-6 py-3.5">
                            {% if dispo.statut == 'non_disponible' %}
                                <span class="inline-flex items-center gap-1.5 bg-red-100 text-red-600 text-xs font-bold px-2.5 py-1 rounded-full border border-red-200">
                                    <i class="fa-solid fa-xmark"></i> Annulée
                                </span>
                            {% else %}
                                <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full border border-green-200">
                                    <i class="fa-solid fa-check"></i> Disponible
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>
{% endfor %}
</div>

{% endif %}
{% endblock %}
