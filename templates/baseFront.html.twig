<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VitalTech - Espace Patient</title>
    {% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #F3F4F6; }
        .sidebar-link:hover { background-color: #EFF6FF; color: #2563EB; transform: translateX(5px); }
        .sidebar-link { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .card-hover { transition: all 0.3s ease; }
    </style>
    {% endblock %}
</head>
<body class="flex h-screen overflow-hidden">

<aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col">
    <div class="p-6 flex items-center justify-center border-b border-gray-100">
        <div class="flex items-center gap-2 text-blue-600 font-bold text-2xl">
            <i class="fa-solid fa-heart-pulse"></i>
            <span>VitalTech</span>
        </div>
    </div>

    <nav class="flex-1 p-4 space-y-2">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 pl-2">Menu Principal</p>

        <a href="{{ path('patient_dashboard') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_dashboard' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-chart-line w-5"></i> Tableau de Bord
        </a>
        <a href="{{ path('showAllRdvfront')}}" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
            <i class="fa-solid fa-user-doctor w-5"></i> Rendez-vous
        </a>
        <a href="{{ path('patient_medicaments') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_medicaments' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-pills w-5"></i> Medicaments
        </a>
        <a href="{{ path('patient_dossier') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_dossier' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-notes-medical w-5"></i> Mes Donnees
        </a>
        <a href="{{ path('patient_stats') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_stats' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-chart-pie w-5"></i> Mes Statistiques
        </a>

        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 pl-2">Communaute</p>
        <a href="{{ path('app_missions_index')}}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_missions_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-hand-holding-heart w-5 text-orange-400"></i> Benevolat
        </a>
        <a href="{{ path('app_forum_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_forum_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-comments w-5 text-blue-400"></i> Forum
        </a>
        <a href="{{ path('app_donation_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_donation_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-bullhorn w-5 text-purple-400"></i> Annonces & Donations
        </a>
        <a href="{{ path('app_assoc_mission_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_assoc_mission_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-briefcase w-5 text-emerald-400"></i> Gerer mes Missions
        </a>
        <a href="{{ path('chatbot') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'chatbot' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
            <i class="fa-solid fa-robot w-5 text-indigo-400"></i> Chatbot
        </a>

        {% if is_granted('ROLE_ADMIN') %}
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 pl-2">Administration</p>
            <a href="{{ path('admin_user_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 text-indigo-600 rounded-xl font-medium">
                <i class="fa-solid fa-shield-halved w-5"></i> Backoffice
            </a>
        {% endif %}
    </nav>

    <div class="p-4 border-t border-gray-100">
        {% if app.user %}
            <div class="space-y-2">
                <a href="{{ path('account_show')|default('#') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-blue-600 transition-colors">
                    <i class="fa-solid fa-user"></i> Mon compte
                </a>
                <a href="{{ path('front_logout') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-red-500 transition-colors">
                    <i class="fa-solid fa-right-from-bracket"></i> Deconnexion
                </a>
            </div>
        {% else %}
            <div class="space-y-2">
                <a href="{{ path('front_login') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-blue-600 transition-colors">
                    <i class="fa-solid fa-right-to-bracket"></i> Connexion
                </a>
                <a href="{{ path('front_register') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-green-600 transition-colors">
                    <i class="fa-solid fa-user-plus"></i> Inscription
                </a>
            </div>
        {% endif %}
    </div>
</aside>

<main class="flex-1 overflow-y-auto">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
        <div class="flex items-center justify-between px-8 py-4">
            {% block title %}
            <h1 class="text-2xl font-bold text-gray-800">Bonjour, {% if app.user %}{{ app.user.prenom }}{% else %}Patient{% endif %}</h1>
            {% endblock %}

            <div class="flex items-center gap-6">
                <div class="relative">
                    <button id="notifBtn" type="button" class="relative text-gray-500 hover:text-blue-600 transition">
                        <i class="fa-solid fa-bell text-xl"></i>
                        <span id="notifCount" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs min-w-[16px] h-4 px-1 rounded-full flex items-center justify-center">0</span>
                    </button>
                    <div id="notifDropdown" class="hidden absolute right-0 mt-3 w-96 max-w-[90vw] bg-white border border-gray-200 rounded-xl shadow-xl z-50">
                        <div class="px-4 py-3 border-b border-gray-100 text-sm font-semibold text-gray-800">Notifications</div>
                        <div id="notifList" class="max-h-80 overflow-y-auto">
                            <div class="px-4 py-6 text-sm text-gray-500 text-center">Aucune notification.</div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-3 pl-6 border-l border-gray-200">
                    <div class="text-right hidden sm:block">
                        {% if app.user %}
                            <p class="text-sm font-bold text-gray-700">{{ app.user.prenom }} {{ app.user.nom }}</p>
                            <p class="text-xs text-gray-500">{{ app.user.email }}</p>
                        {% else %}
                            <p class="text-sm font-bold text-gray-700">Invite</p>
                            <p class="text-xs text-gray-500">Veuillez vous connecter</p>
                        {% endif %}
                    </div>
                    <img src="https://ui-avatars.com/api/?name={{ app.user ? app.user.prenom ~ '+' ~ app.user.nom : 'Invited+User' }}&background=0D8ABC&color=fff" alt="Profil" class="w-10 h-10 rounded-full border-2 border-white shadow-sm">
                </div>
            </div>
        </div>
    </header>

    <div class="px-8 pt-6">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-4 rounded-2xl shadow-sm border animate-bounce flex items-center gap-3
                    {% if label == 'success' %}bg-green-50 text-green-700 border-green-200{% elseif label == 'danger' or label == 'error' %}bg-red-50 text-red-700 border-red-200{% else %}bg-blue-50 text-blue-700 border-blue-200{% endif %}">
                    <i class="fa-solid {% if label == 'success' %}fa-circle-check{% else %}fa-circle-exclamation{% endif %} text-lg"></i>
                    <span class="font-bold text-sm">{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% block body %}{% endblock %}
</main>

{% block javascripts %}
<script>
    const chartCanvas = document.getElementById('healthChart');
    if (chartCanvas) {
        const ctx = chartCanvas.getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'],
                datasets: [{
                    label: 'Glycemie (g/L)',
                    data: [0.95, 1.02, 0.98, 1.10, 0.92, 0.96, 0.94],
                    borderColor: '#3B82F6',
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(59, 130, 246, 0.05)'
                }, {
                    label: 'Tension (Sys)',
                    data: [12.1, 12.3, 11.9, 12.5, 12.0, 12.2, 11.8],
                    borderColor: '#EF4444',
                    tension: 0.4,
                    borderDash: [5, 5]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end' } },
                scales: {
                    y: { beginAtZero: false, grid: { borderDash: [2, 2] } },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    const notifBtn = document.getElementById('notifBtn');
    const notifCount = document.getElementById('notifCount');
    const notifDropdown = document.getElementById('notifDropdown');
    const notifList = document.getElementById('notifList');

    async function marquerNotificationLue(id) {
        await fetch(`/api/notifications/lu/${id}`, { method: 'POST' });
    }

    async function chargerNotifications() {
        try {
            const response = await fetch('/api/notifications');
            const data = await response.json();
            const notifications = Array.isArray(data.notifications) ? data.notifications : [];
            const count = Number.isInteger(data.count) ? data.count : notifications.length;

            if (count > 0) {
                notifCount.textContent = String(count);
                notifCount.classList.remove('hidden');
            } else {
                notifCount.classList.add('hidden');
            }

            if (notifications.length === 0) {
                notifList.innerHTML = '<div class="px-4 py-6 text-sm text-gray-500 text-center">Aucune notification.</div>';
                return;
            }

            notifList.innerHTML = notifications.map((n) => `
                <button type="button" data-id="${n.id}" class="w-full text-left px-4 py-3 border-b border-gray-100 hover:bg-gray-50 transition">
                    <div class="text-sm text-gray-800">${n.message ?? ''}</div>
                    <div class="text-xs text-gray-500 mt-1">${n.heure ?? ''}</div>
                </button>
            `).join('');

            notifList.querySelectorAll('button[data-id]').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    if (!id) {
                        return;
                    }
                    await marquerNotificationLue(id);
                    await chargerNotifications();
                });
            });
        } catch (e) {
            notifList.innerHTML = '<div class="px-4 py-6 text-sm text-red-600 text-center">Erreur de chargement des notifications.</div>';
        }
    }

    if (notifBtn && notifDropdown) {
        notifBtn.addEventListener('click', () => {
            notifDropdown.classList.toggle('hidden');
        });

        document.addEventListener('click', (event) => {
            if (!notifDropdown.contains(event.target) && !notifBtn.contains(event.target)) {
                notifDropdown.classList.add('hidden');
            }
        });
    }

    if (notifList && notifCount) {
        chargerNotifications();
        setInterval(chargerNotifications, 20000);
    }
</script>
{% endblock %}

</body>
</html>
