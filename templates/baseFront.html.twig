<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VitalTech - Espace Patient</title>
    {% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #F3F4F6; }
        .sidebar-link:hover { background-color: #EFF6FF; color: #2563EB; transform: translateX(5px); }
        .sidebar-link { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .card-hover { transition: all 0.3s ease; }
        .form-error, ul.form-errors li {
    color: #dc2626 !important;
    font-size: 0.75rem !important;
    margin-top: 0.25rem !important;
    display: block !important;
}
    </style>
    {% endblock %}

</head>
<body class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col">
        <div class="p-6 flex items-center justify-center border-b border-gray-100">
            <div class="flex items-center gap-2 text-blue-600 font-bold text-2xl">
                <i class="fa-solid fa-heart-pulse"></i>
                <span>VitalTech</span>
            </div>
        </div>

        <nav class="flex-1 p-4 space-y-2">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 pl-2">Menu Principal</p>

            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-blue-600 bg-blue-50 rounded-xl font-medium">
                <i class="fa-solid fa-chart-line w-5"></i> Tableau de Bord
            </a>
            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-user-doctor w-5"></i> Rendez-vous
            </a>
            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-pills w-5"></i> Médicaments
            </a>
            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-notes-medical w-5"></i> Mes Données
            </a>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 pl-2">Communauté</p>
            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-hand-holding-heart w-5"></i> Bénévolat
            </a>
            <a href="#" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-calendar-day w-5"></i> Événements
            </a>
        </nav>

        <div class="p-4 border-t border-gray-100">
            <a href="#" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-red-500 transition-colors">
                <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
            </a>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
        <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
            <div class="flex items-center justify-between px-8 py-4">
                {% block title %}
                <h1 class="text-2xl font-bold text-gray-800">Bonjour, Patient 👋</h1>
                {% endblock %}

                <div class="flex items-center gap-6">

                    {# ===== CLOCHE NOTIFICATIONS API ===== #}
                    <div class="relative" id="notifWrapper">
                        <button onclick="toggleNotifDropdown()"
                            class="relative text-gray-500 hover:text-blue-600 transition">
                            <i class="fa-solid fa-bell text-xl"></i>
                            <span id="notifBadge"
                                class="absolute -top-1 -right-1 bg-red-500 text-white text-xs w-4 h-4 rounded-full flex items-center justify-center hidden">
                                0
                            </span>
                        </button>

                        {# Dropdown #}
                        <div id="notifDropdown"
                            class="hidden absolute right-0 mt-3 w-80 bg-white rounded-2xl shadow-2xl border border-slate-100 z-50 overflow-hidden">

                            {# Header #}
                            <div class="flex justify-between items-center px-4 py-3 border-b border-slate-100">
                                <p class="font-bold text-slate-800 text-sm">
                                    <i class="fa-solid fa-bell text-blue-600 mr-1"></i> Notifications
                                </p>
                                <span id="notifCount"
                                    class="bg-red-100 text-red-600 text-xs font-bold px-2 py-0.5 rounded-full">
                                    0
                                </span>
                            </div>

                            {# Liste #}
                            <div id="notifList" class="max-h-72 overflow-y-auto divide-y divide-slate-50">
                                <p class="text-center text-slate-400 text-sm py-6">
                                    <i class="fa-solid fa-spinner fa-spin mr-1"></i> Chargement...
                                </p>
                            </div>

                            {# Footer #}
                            <div class="px-4 py-2 border-t border-slate-100 text-center">
                                <button onclick="toutMarquerLu()"
                                    class="text-xs text-blue-600 hover:underline font-medium">
                                    Tout marquer comme lu
                                </button>
                            </div>
                        </div>
                    </div>
                    {# ===== FIN CLOCHE ===== #}

                    <div class="flex items-center gap-3 pl-6 border-l border-gray-200">
                        <div class="text-right hidden sm:block">
                            {% block username %}
                            <p class="text-sm font-bold text-gray-700">Patient Name</p>
                            {% endblock %}
                            {% block userid %}
                            <p class="text-xs text-gray-500">Patient ID: #8492</p>
                            {% endblock %}
                        </div>
                        <img src="https://ui-avatars.com/api/?name=Ahmed+Ben+Salah&background=0D8ABC&color=fff" alt="Profil" class="w-10 h-10 rounded-full border-2 border-white shadow-sm">
                    </div>
                </div>
            </div>
        </header>

        {% block body %}
        {% endblock %}

    </main>

{% block javascripts %}
    <script>
        // ===== CHART (uniquement si l'élément existe) =====
        const ctxEl = document.getElementById('healthChart');
        if (ctxEl) {
            const ctx = ctxEl.getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'],
                    datasets: [{
                        label: 'Glycémie (g/L)',
                        data: [0.95, 1.02, 0.98, 1.10, 0.92, 0.96, 0.94],
                        borderColor: '#3B82F6',
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(59, 130, 246, 0.05)'
                    },
                    {
                        label: 'Tension (Sys)',
                        data: [12.1, 12.3, 11.9, 12.5, 12.0, 12.2, 11.8],
                        borderColor: '#EF4444',
                        tension: 0.4,
                        borderDash: [5, 5]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end' }
                    },
                    scales: {
                        y: { beginAtZero: false, grid: { borderDash: [2, 2] } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        // ===== API NOTIFICATIONS =====
        async function fetchNotifications() {
            try {
                const res  = await fetch('/api/notifications');
                const data = await res.json();

                const badge = document.getElementById('notifBadge');
                const count = document.getElementById('notifCount');
                const list  = document.getElementById('notifList');

                if (!badge || !count || !list) return;

                // Mettre à jour le badge
                if (data.count > 0) {
                    badge.textContent = data.count;
                    badge.classList.remove('hidden');
                    count.textContent = data.count;
                } else {
                    badge.classList.add('hidden');
                    count.textContent = '0';
                }

                // Liste vide
                if (data.notifications.length === 0) {
                    list.innerHTML = `
                        <div class="text-center py-8 text-slate-400">
                            <i class="fa-solid fa-bell-slash text-2xl mb-2 block"></i>
                            <p class="text-sm">Aucune nouvelle notification</p>
                        </div>`;
                    return;
                }

                // Afficher les notifications
                list.innerHTML = data.notifications.map(n => `
                    <div class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition cursor-pointer"
                         onclick="marquerLu(${n.id}, this)">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 ${
                            n.type === 'success' ? 'bg-green-100 text-green-600' :
                            n.type === 'danger'  ? 'bg-red-100 text-red-600'    :
                                                   'bg-orange-100 text-orange-600'
                        }">
                            <i class="fa-solid fa-${
                                n.type === 'success' ? 'check' :
                                n.type === 'danger'  ? 'xmark' : 'clock'
                            } text-xs"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm text-slate-700 font-medium leading-snug">${n.message}</p>
                            <p class="text-xs text-slate-400 mt-0.5">
                                <i class="fa-regular fa-clock mr-1"></i>${n.heure}
                            </p>
                        </div>
                        <i class="fa-solid fa-xmark text-slate-300 hover:text-red-400 text-xs mt-1 flex-shrink-0"></i>
                    </div>
                `).join('');

            } catch(e) {
                console.error('Erreur notifications:', e);
            }
        }

        async function marquerLu(id, element) {
            await fetch(`/api/notifications/lu/${id}`, { method: 'POST' });
            element.remove();
            fetchNotifications();
        }

        async function toutMarquerLu() {
            const items = document.querySelectorAll('#notifList [onclick]');
            for (const item of items) {
                const match = item.getAttribute('onclick').match(/\d+/);
                if (match) {
                    await fetch(`/api/notifications/lu/${match[0]}`, { method: 'POST' });
                }
            }
            fetchNotifications();
        }

        function toggleNotifDropdown() {
            document.getElementById('notifDropdown').classList.toggle('hidden');
        }

        // Fermer si clic en dehors
        document.addEventListener('click', function(e) {
            const wrapper = document.getElementById('notifWrapper');
            if (wrapper && !wrapper.contains(e.target)) {
                document.getElementById('notifDropdown').classList.add('hidden');
            }
        });

        // Charger au démarrage + toutes les 30 secondes
        fetchNotifications();
        setInterval(fetchNotifications, 30000);
    </script>
{% endblock %}

</body>
</html>
