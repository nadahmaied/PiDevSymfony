<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VitalTech - Espace Patient</title>
    {% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #F3F4F6; }
        .sidebar-link:hover { background-color: #EFF6FF; color: #2563EB; transform: translateX(5px); }
        .sidebar-link { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .card-hover { transition: all 0.3s ease; }
    </style>
    {% endblock %}
</head>
<body class="flex h-screen overflow-hidden">

    <aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col">
        <div class="p-6 flex items-center justify-center border-b border-gray-100">
            <div class="flex items-center gap-2 text-blue-600 font-bold text-2xl">
                <i class="fa-solid fa-heart-pulse"></i>
                <span>VitalTech</span>
            </div>
        </div>

        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 pl-2">Menu Principal</p>

            <a href="{{ path('patient_dashboard') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_dashboard' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-chart-line w-5"></i> Tableau de Bord
            </a>
            <a href="{{ path('showAllRdvfront')}}" class="sidebar-link flex items-center gap-3 px-4 py-3 text-gray-600 rounded-xl font-medium">
                <i class="fa-solid fa-user-doctor w-5"></i> Rendez-vous
            </a>
            <a href="{{ path('patient_medicaments') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_medicaments' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-pills w-5"></i> Médicaments
            </a>
            <a href="{{ path('patient_dossier') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_dossier' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-notes-medical w-5"></i> Mes Données
            </a>
            <a href="{{ path('patient_stats') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'patient_stats' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-chart-pie w-5"></i> Mes Statistiques
            </a>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 pl-2">Communauté</p>
            <a href="{{ path('app_missions_index')}}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_missions_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-hand-holding-heart w-5 text-orange-400"></i> Bénévolat
            </a>
            <a href="{{ path('app_forum_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_forum_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-comments w-5 text-blue-400"></i> Forum
            </a>
            <a href="{{ path('app_donation_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_donation_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-bullhorn w-5 text-purple-400"></i> Annonces & Donations
            </a>
            <a href="{{ path('app_assoc_mission_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'app_assoc_mission_index' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-briefcase w-5 text-emerald-400"></i> Gérer mes Missions
            </a>
            <a href="{{ path('chatbot') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 {{ app.request.get('_route') == 'chatbot' ? 'text-blue-600 bg-blue-50' : 'text-gray-600' }} rounded-xl font-medium">
                <i class="fa-solid fa-robot w-5 text-indigo-400"></i> Chatbot
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 pl-2">Administration</p>
                <a href="{{ path('admin_user_index') }}" class="sidebar-link flex items-center gap-3 px-4 py-3 text-indigo-600 rounded-xl font-medium">
                    <i class="fa-solid fa-shield-halved w-5"></i> Backoffice
                </a>
            {% endif %}
        </nav>

        <div class="p-4 border-t border-gray-100">
            {% if app.user %}
                <div class="space-y-2">
                    <a href="{{ path('account_show')|default('#') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-blue-600 transition-colors rounded-xl">
                        <i class="fa-solid fa-user"></i> Mon compte
                    </a>
                    <a href="{{ path('front_logout') }}"
                       class="flex items-center justify-center gap-2 w-full px-4 py-2.5
                              bg-red-50 hover:bg-red-100 text-red-600 font-semibold
                              rounded-xl border border-red-200 transition-all duration-200">
                        <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
                    </a>
                </div>
            {% else %}
                <div class="space-y-2">
                    <a href="{{ path('front_login') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-blue-600 transition-colors">
                        <i class="fa-solid fa-right-to-bracket"></i> Connexion
                    </a>
                    <a href="{{ path('front_register') }}" class="flex items-center gap-3 px-4 py-2 text-gray-600 hover:text-green-600 transition-colors">
                        <i class="fa-solid fa-user-plus"></i> Inscription
                    </a>
                </div>
            {% endif %}
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto">
        <header class="bg-white border-b border-gray-200 sticky top-0 z-30">
            <div class="flex items-center justify-between px-8 py-4">
               {% block title %}
               <h1 class="text-2xl font-bold text-gray-800">Bonjour, {% if app.user %}{{ app.user.prenom }}{% else %}Patient{% endif %} 👋</h1>
               {% endblock %}

                <div class="flex items-center gap-6">

                    {# ── Cloche notifications ── #}
                    <div class="relative" id="notifWrapper">
                        <button onclick="toggleNotifDropdown()"
                                class="relative text-gray-500 hover:text-blue-600 transition focus:outline-none">
                            <i class="fa-solid fa-bell text-xl"></i>
                            <span id="notifBadge"
                                  class="absolute -top-1 -right-1 bg-red-500 text-white text-xs w-4 h-4 rounded-full items-center justify-center hidden">
                            </span>
                        </button>

                        {# Dropdown notifications #}
                        <div id="notifDropdown"
                             class="hidden absolute right-0 mt-3 w-80 bg-white rounded-2xl shadow-2xl border border-gray-100 z-50 overflow-hidden">

                            {# Header dropdown #}
                            <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 bg-gray-50">
                                <span class="font-bold text-gray-800 flex items-center gap-2">
                                    <i class="fa-solid fa-bell text-blue-500"></i>
                                    Notifications
                                    <span id="notifCount"
                                          class="bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full">
                                        0
                                    </span>
                                </span>
                                <button onclick="marquerToutLu()"
                                        class="text-xs text-blue-600 hover:underline font-medium">
                                    Tout marquer comme lu
                                </button>
                            </div>

                            {# Liste des notifications #}
                            <div id="notifList" class="max-h-72 overflow-y-auto divide-y divide-gray-50">
                                <p class="text-center text-gray-400 text-sm py-6">
                                    <i class="fa-solid fa-spinner fa-spin mr-2"></i> Chargement...
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 pl-6 border-l border-gray-200">
                        <div class="text-right hidden sm:block">
                            {% if app.user %}
                                <p class="text-sm font-bold text-gray-700">{{ app.user.prenom }} {{ app.user.nom }}</p>
                                <p class="text-xs text-gray-500">{{ app.user.email }}</p>
                            {% else %}
                                <p class="text-sm font-bold text-gray-700">Invité</p>
                                <p class="text-xs text-gray-500">Veuillez vous connecter</p>
                            {% endif %}
                        </div>
                        <img src="https://ui-avatars.com/api/?name={{ app.user ? app.user.prenom ~ '+' ~ app.user.nom : 'Invited+User' }}&background=0D8ABC&color=fff"
                             alt="Profil" class="w-10 h-10 rounded-full border-2 border-white shadow-sm">
                    </div>
                </div>
            </div>
        </header>

        <div class="px-8 pt-6">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 p-4 rounded-2xl shadow-sm border animate-bounce flex items-center gap-3
                        {% if label == 'success' %}bg-green-50 text-green-700 border-green-200
                        {% elseif label == 'danger' or label == 'error' %}bg-red-50 text-red-700 border-red-200
                        {% else %}bg-blue-50 text-blue-700 border-blue-200{% endif %}">
                        <i class="fa-solid {% if label == 'success' %}fa-circle-check{% else %}fa-circle-exclamation{% endif %} text-lg"></i>
                        <span class="font-bold text-sm">{{ message }}</span>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}
    <script>
        const ctx = document.getElementById('healthChart');
        if (ctx) {
            new Chart(ctx.getContext('2d'), {
                type: 'line',
                data: {
                    labels: ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'],
                    datasets: [{
                        label: 'Glycémie (g/L)',
                        data: [0.95, 1.02, 0.98, 1.10, 0.92, 0.96, 0.94],
                        borderColor: '#3B82F6', tension: 0.4, fill: true,
                        backgroundColor: 'rgba(59, 130, 246, 0.05)'
                    }, {
                        label: 'Tension (Sys)',
                        data: [12.1, 12.3, 11.9, 12.5, 12.0, 12.2, 11.8],
                        borderColor: '#EF4444', tension: 0.4, borderDash: [5, 5]
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top', align: 'end' } },
                    scales: {
                        y: { beginAtZero: false, grid: { borderDash: [2, 2] } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    </script>

    {# ── Notifications JS ── #}
    <script>
    let notifOpen = false;
    let allNotifIds = [];

    // Ouvrir / fermer le dropdown
    function toggleNotifDropdown() {
        notifOpen = !notifOpen;
        document.getElementById('notifDropdown').classList.toggle('hidden', !notifOpen);
        if (notifOpen) fetchNotifications();
    }

    // Fermer si clic en dehors
    document.addEventListener('click', function(e) {
        const wrapper = document.getElementById('notifWrapper');
        if (wrapper && !wrapper.contains(e.target)) {
            notifOpen = false;
            document.getElementById('notifDropdown').classList.add('hidden');
        }
    });

    // Couleurs par type
    const typeConfig = {
        success: { bg: 'bg-green-50', border: 'border-green-100', icon: 'fa-circle-check text-green-500', text: 'text-green-700' },
        danger:  { bg: 'bg-red-50',   border: 'border-red-100',   icon: 'fa-circle-xmark text-red-500',   text: 'text-red-700'   },
        warning: { bg: 'bg-orange-50', border: 'border-orange-100', icon: 'fa-clock text-orange-500',      text: 'text-orange-700'},
    };

    async function fetchNotifications() {
        try {
            const res  = await fetch('/api/notifications');
            const data = await res.json();

            const badge    = document.getElementById('notifBadge');
            const count    = document.getElementById('notifCount');
            const list     = document.getElementById('notifList');
            const notifs   = data.notifications || [];
            allNotifIds    = notifs.map(n => n.id);

            // Mettre à jour le badge
            if (data.count > 0) {
                badge.textContent = data.count;
                badge.classList.remove('hidden');
                badge.classList.add('flex');
            } else {
                badge.classList.add('hidden');
                badge.classList.remove('flex');
            }
            count.textContent = data.count;

            // Rendre la liste
            if (notifs.length === 0) {
                list.innerHTML = `
                    <div class="text-center py-8 text-gray-400">
                        <i class="fa-solid fa-bell-slash text-3xl mb-2 block opacity-40"></i>
                        <p class="text-sm">Aucune nouvelle notification</p>
                    </div>`;
                return;
            }

            list.innerHTML = notifs.map(n => {
                const cfg = typeConfig[n.type] || typeConfig.warning;
                return `
                <div class="flex items-start gap-3 px-4 py-3 ${cfg.bg} ${cfg.border} border-b hover:brightness-95 transition cursor-pointer"
                     onclick="marquerLu(${n.id}, this)">
                    <div class="mt-0.5 flex-shrink-0">
                        <i class="fa-solid ${cfg.icon} text-lg"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold ${cfg.text} leading-snug">${n.message}</p>
                        <p class="text-xs text-gray-400 mt-1"><i class="fa-regular fa-clock mr-1"></i>${n.heure}</p>
                    </div>
                    <button class="flex-shrink-0 text-gray-300 hover:text-gray-500 transition ml-1 mt-0.5" title="Marquer comme lu">
                        <i class="fa-solid fa-xmark text-xs"></i>
                    </button>
                </div>`;
            }).join('');

        } catch(e) {
            document.getElementById('notifList').innerHTML =
                `<p class="text-center text-red-400 text-sm py-6">Erreur de chargement</p>`;
        }
    }

    async function marquerLu(id, el) {
        try {
            await fetch(`/api/notifications/lu/${id}`, { method: 'POST' });
            // Supprimer l'élément du DOM avec animation
            el.style.transition = 'opacity 0.2s, max-height 0.3s';
            el.style.opacity = '0';
            setTimeout(() => { el.remove(); fetchNotifications(); }, 250);
        } catch(e) { console.error(e); }
    }

    async function marquerToutLu() {
        for (const id of allNotifIds) {
            await fetch(`/api/notifications/lu/${id}`, { method: 'POST' });
        }
        fetchNotifications();
    }

    // Polling auto toutes les 30 secondes (badge uniquement)
    async function pollBadge() {
        try {
            const res  = await fetch('/api/notifications');
            const data = await res.json();
            const badge = document.getElementById('notifBadge');
            const count = document.getElementById('notifCount');
            if (data.count > 0) {
                badge.textContent = data.count;
                badge.classList.remove('hidden');
                badge.classList.add('flex');
            } else {
                badge.classList.add('hidden');
                badge.classList.remove('flex');
            }
            if (count) count.textContent = data.count;
        } catch(e) {}
    }
    pollBadge();
    setInterval(pollBadge, 30000);
    </script>
    {% endblock %}

    {# ── Chatbot widget flottant ── #}
    {% include 'rdv/front/_chatbot.html.twig' %}

</body>
</html>
