{% extends 'baseFront.html.twig' %}

{% block title %}{{ mission.titre }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12">
    
    <a href="{{ path('app_missions_index') }}" class="inline-flex items-center text-gray-500 hover:text-orange-600 mb-6 transition">
        <i class="fa-solid fa-arrow-left mr-2"></i> Retour aux missions
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-8">
            
            <div class="rounded-2xl overflow-hidden shadow-lg h-96 relative group">
                <img src="{{ mission.photo ? asset('uploads/missions/' ~ mission.photo) : 'https://images.unsplash.com/photo-1593113598332-cd288d649433?w=1000' }}" 
                     class="w-full h-full object-cover">
                
                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur px-4 py-2 rounded-full shadow text-orange-600 font-bold">
                    <i class="fa-solid fa-location-dot mr-2"></i> {{ mission.lieu }}
                </div>
            </div>

            <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
                <h1 class="text-4xl font-bold text-gray-800 mb-4">{{ mission.titre }}</h1>
                
                <div class="flex items-center gap-6 text-gray-500 mb-8 border-b border-gray-100 pb-6">
                    <span class="flex items-center gap-2">
                        <i class="fa-regular fa-calendar text-xl text-blue-500"></i>
                        Du {{ mission.dateDebut|date('d/m/Y') }} au {{ mission.dateFin|date('d/m/Y') }}
                    </span>
                    <span class="flex items-center gap-2">
                        <i class="fa-solid fa-users text-xl text-green-500"></i>
                        Places limitées
                    </span>
                </div>

                <h3 class="text-xl font-bold text-gray-800 mb-4">À propos de la mission</h3>
                <p class="text-gray-600 leading-relaxed text-lg whitespace-pre-line">
                    {{ mission.description }}
                </p>
            </div>
            
            <div class="bg-blue-50 rounded-2xl p-8 flex justify-between items-center border border-blue-100">
                <div>
                    <h3 class="font-bold text-blue-900 mb-1">Cette mission vous intéresse ?</h3>
                    <p class="text-blue-700 text-sm">Donnez votre avis ou ajoutez-la à vos favoris.</p>
                </div>
                
                <div class="flex gap-4 items-center">
                    {% set totalRating = 0 %}
                    {% for r in mission.missionRatings %}
                        {% set totalRating = totalRating + r.note %}
                    {% endfor %}
                    {% set avg = mission.missionRatings|length > 0 ? (totalRating / mission.missionRatings|length) : 0 %}

                    <div class="flex text-yellow-400 js-rating-stars"
                         data-rate-base="{{ path('app_mission_rate_action', {'id': mission.id, 'note': 0}) }}">
                        {% for i in 1..5 %}
                            <button type="button" class="js-rate-star px-0.5" data-note="{{ i }}" aria-label="Noter {{ i }}/5">
                                <i class="{{ i <= avg ? 'fa-solid' : 'fa-regular' }} fa-star"></i>
                            </button>
                        {% endfor %}
                    </div>
                    <span class="text-xs text-blue-800 js-rating-count">({{ mission.missionRatings|length }} avis)</span>

                    <button data-url="{{ path('app_mission_like_action', {'id': mission.id}) }}" class="js-like-button bg-white text-gray-400 w-12 h-12 rounded-full flex items-center justify-center shadow hover:text-red-500 transition">
                        <i class="fa-heart text-xl {% if app.user and mission.missionLikes|filter(l => l.user == app.user)|length > 0 %} fa-solid text-red-500 {% else %} fa-regular {% endif %}"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 sticky top-8">
                <h3 class="text-xl font-bold text-gray-800 mb-2">Participer</h3>
                <p class="text-gray-500 text-sm mb-6">Rejoignez l'équipe et faites la différence.</p>

                <div class="space-y-4">
                    <a href="{{ path('app_missions_apply', {'id': mission.id}) }}" class="block w-full text-center bg-orange-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-orange-700 transition shadow-lg hover:shadow-orange-200 transform hover:-translate-y-1">
                        Je postule maintenant !
                    </a>
                    
                    
                    <button
                        type="button"
                        id="js-mission-ai-btn"
                        data-url="{{ path('app_mission_ai_advice', {'id': mission.id}) }}"
                        class="block w-full text-center bg-slate-100 text-slate-700 py-3 rounded-xl font-bold text-sm hover:bg-slate-200 transition"
                    >
                        <i class="fa-solid fa-wand-magic-sparkles mr-1"></i> Aide IA pour cette mission
                    </button>

                    <div id="js-mission-ai-result" class="hidden text-sm text-slate-700 bg-slate-50 border border-slate-200 rounded-xl p-4 whitespace-pre-line"></div>

                    <p class="text-center text-xs text-gray-400 mt-4">
                        <i class="fa-solid fa-shield-halved mr-1"></i> Candidature simplifiée et sécurisée
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    document.querySelectorAll('.js-like-button').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const url = this.dataset.url;
            const icon = this.querySelector('i');
            this.classList.add('scale-125');
            setTimeout(() => this.classList.remove('scale-125'), 200);

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data.code === 200) {
                        if (data.isLiked) {
                            icon.classList.remove('fa-regular', 'text-gray-400');
                            icon.classList.add('fa-solid', 'text-red-500');
                        } else {
                            icon.classList.remove('fa-solid', 'text-red-500');
                            icon.classList.add('fa-regular', 'text-gray-400');
                        }
                    } else if (data.code === 403) {
                        alert("Connectez-vous pour aimer !");
                    }
                });
        });
    });

    document.querySelectorAll('.js-rating-stars').forEach(block => {
        const baseUrl = block.dataset.rateBase;
        const countEl = document.querySelector('.js-rating-count');

        const paintStars = (value) => {
            block.querySelectorAll('.js-rate-star').forEach(btn => {
                const note = parseInt(btn.dataset.note, 10);
                const icon = btn.querySelector('i');
                if (note <= value) {
                    icon.classList.remove('fa-regular');
                    icon.classList.add('fa-solid');
                } else {
                    icon.classList.remove('fa-solid');
                    icon.classList.add('fa-regular');
                }
            });
        };

        block.querySelectorAll('.js-rate-star').forEach(btn => {
            btn.addEventListener('click', function () {
                const note = parseInt(this.dataset.note, 10);
                const url = baseUrl.replace('/0', '/' + note);

                fetch(url, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.code === 200) {
                            paintStars(Math.round(data.average));
                            if (countEl) {
                                countEl.textContent = `(${data.count} avis)`;
                            }
                        } else if (data.code === 403) {
                            alert('Connectez-vous pour noter !');
                        }
                    })
                    .catch(err => console.error('Erreur rating:', err));
            });
        });
    });

    const aiBtn = document.getElementById('js-mission-ai-btn');
    const aiResult = document.getElementById('js-mission-ai-result');
    if (aiBtn && aiResult) {
        const original = aiBtn.innerHTML;
        aiBtn.addEventListener('click', async () => {
            aiBtn.disabled = true;
            aiBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1"></i> Generation...';

            try {
                const response = await fetch(aiBtn.dataset.url, { method: 'POST' });
                const data = await response.json();
                if (!data.ok) {
                    alert(data.message || 'Assistance IA indisponible.');
                } else {
                    aiResult.textContent = data.advice || '';
                    aiResult.classList.remove('hidden');
                }
            } catch (e) {
                alert('Erreur reseau.');
            } finally {
                aiBtn.disabled = false;
                aiBtn.innerHTML = original;
            }
        });
    }
</script>
{% endblock %}




