{% extends 'baseBack.html.twig' %}

{% block title %}Super Admin - Utilisateurs{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Interface Super Admin</h1>
            <p class="text-sm text-gray-500">Gestion des roles utilisateurs (admin/user).</p>
        </div>

        <form method="get" class="flex items-center gap-2">
            <input
                type="text"
                name="q"
                value="{{ q }}"
                placeholder="Rechercher un utilisateur..."
                class="w-72 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            >
            <button class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700 transition">
                Rechercher
            </button>
        </form>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-3 rounded-lg border px-4 py-3 text-sm
                {% if label == 'success' %}border-green-200 bg-green-50 text-green-800
                {% elseif label == 'warning' %}border-yellow-200 bg-yellow-50 text-yellow-800
                {% else %}border-blue-200 bg-blue-50 text-blue-800{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr class="text-left text-xs font-semibold uppercase text-gray-500">
                    <th class="px-4 py-3">ID</th>
                    <th class="px-4 py-3">Nom</th>
                    <th class="px-4 py-3">Email</th>
                    <th class="px-4 py-3">Role</th>
                    <th class="px-4 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                {% for user in users %}
                    <tr>
                        <td class="px-4 py-3 text-gray-500">#{{ user.id }}</td>
                        <td class="px-4 py-3 text-gray-800">{{ (user.prenom ~ ' ' ~ user.nom)|trim }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ user.email }}</td>
                        <td class="px-4 py-3">
                            {% set role = user.role|default('ROLE_USER') %}
                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold
                                {% if role == 'ROLE_SUPER_ADMIN' %}bg-purple-100 text-purple-700
                                {% elseif role == 'ROLE_ADMIN' %}bg-blue-100 text-blue-700
                                {% else %}bg-gray-100 text-gray-700{% endif %}">
                                {{ role }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-right">
                            {% if user.role == 'ROLE_SUPER_ADMIN' %}
                                <span class="text-xs text-gray-400">Protege</span>
                            {% elseif app.user and app.user.id == user.id %}
                                <span class="text-xs text-gray-400">Vous</span>
                            {% else %}
                                <div class="inline-flex gap-2">
                                    <form method="post" action="{{ path('app_super_admin_set_role', {'id': user.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('super_admin_role_' ~ user.id) }}">
                                        <input type="hidden" name="role" value="ROLE_ADMIN">
                                        <button class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700 transition">
                                            Rendre admin
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_super_admin_set_role', {'id': user.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('super_admin_role_' ~ user.id) }}">
                                        <input type="hidden" name="role" value="ROLE_USER">
                                        <button class="rounded-md bg-gray-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-gray-700 transition">
                                            Retirer admin
                                        </button>
                                    </form>
                                </div>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-gray-500">Aucun utilisateur trouve.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

