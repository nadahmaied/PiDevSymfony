<div style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background-color: #f3f4f6; padding: 24px;">
    <div style="max-width: 560px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; padding: 24px; box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);">
        <h1 style="font-size: 20px; font-weight: 700; color: #0f172a; margin: 0 0 12px 0;">
            Nouveau medecin en attente de validation
        </h1>

        <p style="font-size: 14px; color: #4b5563; margin: 8px 0;">
            Bonjour {{ admin.prenom ?: 'Admin' }},
        </p>

        <p style="font-size: 14px; color: #4b5563; margin: 8px 0;">
            Un nouveau compte medecin vient d'etre cree et attend votre validation.
        </p>

        <div style="margin-top: 16px; padding: 12px; border: 1px solid #e5e7eb; border-radius: 10px; background: #f9fafb;">
            <p style="font-size: 14px; color: #111827; margin: 4px 0;"><strong>Nom:</strong> {{ doctor.nom }} {{ doctor.prenom }}</p>
            <p style="font-size: 14px; color: #111827; margin: 4px 0;"><strong>Email:</strong> {{ doctor.email }}</p>
            <p style="font-size: 14px; color: #111827; margin: 4px 0;"><strong>Statut:</strong> {{ doctor.verificationStatus ?: 'pending_review' }}</p>
        </div>

        <div style="text-align: center; margin-top: 22px;">
            <a href="{{ url('admin_verification_pending') }}"
               style="display: inline-block; padding: 12px 20px; background-color: #2563eb; color: #ffffff; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none;">
                Voir les validations en attente
            </a>
        </div>
    </div>
</div>
