<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - VitalTech</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-sky-50 flex items-center justify-center px-4">
<div class="w-full max-w-2xl">
    <div class="mb-8 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-emerald-500 text-white shadow-lg shadow-emerald-300/60">
            <i class="fa-solid fa-user-plus text-2xl"></i>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-slate-900">Créer un compte patient</h1>
        <p class="mt-1 text-sm text-slate-500">Rejoignez VitalTech et suivez vos données de santé en toute sécurité.</p>
    </div>

    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl shadow-emerald-100/60 p-6 border border-slate-100">
        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-xl bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 text-sm flex items-start gap-2">
                <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="mb-4 rounded-xl bg-amber-50 border border-amber-200 text-amber-700 px-4 py-3 text-sm flex items-start gap-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {{ form_start(registrationForm, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.email, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'vous@example.com'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.email) }}
                </div>
            </div>

            <div class="space-y-1.5">
                {{ form_label(registrationForm.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.nom, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'Votre nom'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.nom) }}
                </div>
            </div>

            <div class="space-y-1.5">
                {{ form_label(registrationForm.prenom, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.prenom, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'Votre prénom'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.prenom) }}
                </div>
            </div>

            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(registrationForm.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.adresse, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'Adresse (optionnel)'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.adresse) }}
                </div>
            </div>

            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(registrationForm.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.telephone, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'Téléphone (optionnel)'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.telephone) }}
                </div>
            </div>

            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(registrationForm.role, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.role, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'id': 'roleSelect'
                    }
                }) }}
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.role) }}
                </div>
            </div>

            <div id="doctor-documents" class="md:col-span-2 space-y-4" style="display: none;">
                <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
                    <div class="flex items-start gap-2">
                        <i class="fa-solid fa-info-circle text-blue-600 mt-0.5"></i>
                        <div class="text-sm text-blue-800">
                            <p class="font-medium">Vérification requise pour les médecins</p>
                            <p class="text-xs mt-1">Veuillez télécharger votre diplôme médical. Notre système vérifiera que votre nom correspond.</p>
                        </div>
                    </div>
                </div>

                <div class="space-y-1.5">
                    {{ form_label(registrationForm.diplomaFile, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                    {{ form_widget(registrationForm.diplomaFile, {
                        'attr': {
                            'class': 'w-full text-sm',
                            'accept': 'image/*,application/pdf'
                        }
                    }) }}
                    <div class="text-xs text-rose-500">
                        {{ form_errors(registrationForm.diplomaFile) }}
                    </div>
                </div>
            </div>

            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(registrationForm.plainPassword, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.plainPassword, {
                    'attr': {
                        'class': 'w-full rounded-xl border border-slate-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/60 text-sm px-3 py-2.5 bg-white',
                        'placeholder': 'Choisissez un mot de passe'
                    }
                }) }}
                <p class="text-[11px] text-slate-400">Minimum 6 caractères.</p>
                <div class="text-xs text-rose-500">
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>
            </div>
        </div>

        <button
            type="submit"
            class="mt-6 w-full inline-flex justify-center items-center px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-emerald-500 hover:bg-emerald-600 shadow-sm shadow-emerald-300/60 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-colors"
        >
            <i class="fa-solid fa-user-check mr-2 text-xs"></i>
            Créer mon compte
        </button>

        {{ form_end(registrationForm) }}

        <p class="mt-4 text-center text-xs text-slate-500">
            Vous avez déjà un compte ?
            <a href="{{ path('front_login') }}" class="font-medium text-emerald-600 hover:text-emerald-700 hover:underline">
                Se connecter
            </a>
        </p>
    </div>

    <p class="mt-6 text-center text-[11px] text-slate-400">
        Accès administrateur ?
        <a href="{{ path('admin_login') }}" class="font-medium text-slate-600 hover:text-slate-800 underline">
            Se connecter au backoffice
        </a>
    </p>
</div>

<script>
    // Show/hide doctor documents based on role selection
    document.addEventListener('DOMContentLoaded', function() {
        // Try multiple ways to find the role select
        let roleSelect = document.getElementById('roleSelect');
        
        // If not found by ID, try by name attribute
        if (!roleSelect) {
            roleSelect = document.querySelector('select[name*="role"]');
            console.log('Found by name selector:', roleSelect);
        }
        
        // If still not found, try finding all selects and look for the one with role options
        if (!roleSelect) {
            const allSelects = document.querySelectorAll('select');
            console.log('All selects found:', allSelects.length);
            allSelects.forEach((select, index) => {
                console.log(`Select ${index}:`, select.name, select.id);
                // Check if this select has ROLE_MEDECIN option
                const options = Array.from(select.options).map(opt => opt.value);
                if (options.includes('ROLE_MEDECIN')) {
                    roleSelect = select;
                    console.log('Found role select by options:', roleSelect);
                }
            });
        }
        
        const doctorDocuments = document.getElementById('doctor-documents');
        
        console.log('Script loaded');
        console.log('Role select:', roleSelect);
        console.log('Doctor documents:', doctorDocuments);
        
        if (roleSelect && doctorDocuments) {
            function toggleDoctorFields() {
                const selectedValue = roleSelect.value;
                console.log('Selected role:', selectedValue);
                
                if (selectedValue === 'ROLE_MEDECIN') {
                    doctorDocuments.style.display = 'block';
                    console.log('Showing doctor documents');
                } else {
                    doctorDocuments.style.display = 'none';
                    console.log('Hiding doctor documents');
                }
            }
            
            // Listen for changes
            roleSelect.addEventListener('change', function() {
                console.log('Role changed');
                toggleDoctorFields();
            });
            
            // Check initial value
            toggleDoctorFields();
        } else {
            console.error('Elements not found!');
            if (!roleSelect) console.error('roleSelect is null');
            if (!doctorDocuments) console.error('doctorDocuments is null');
        }
    });
</script>
</body>
</html>

