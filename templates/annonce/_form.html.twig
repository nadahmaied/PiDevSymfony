{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 space-y-5">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i class="fa-solid fa-bullhorn text-orange-500"></i>
            {{ button_label is defined and button_label == 'Mettre à jour' ? 'Modifier une annonce' : 'Créer une nouvelle annonce' }}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="md:col-span-2 space-y-1.5">
                {{ form_label(form.titreAnnonce, 'Titre de l\'annonce', {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(form.titreAnnonce, {'attr': {'class': 'mt-1 block w-full rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2.5 text-sm text-slate-800 shadow-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none'}}) }}
                {{ form_errors(form.titreAnnonce) }}
            </div>

            <div class="md:col-span-2 space-y-1.5">
                <div class="flex items-center justify-between">
                    {{ form_label(form.description, 'Description détaillée', {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                    <button type="button" id="ai-enhance-btn" class="inline-flex items-center gap-1.5 rounded-lg border border-orange-200 bg-orange-50 px-3 py-1.5 text-xs font-medium text-orange-700 hover:bg-orange-100 transition">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                        Améliorer avec l'IA
                    </button>
                </div>
                {{ form_widget(form.description, {'attr': {'rows': 4, 'class': 'mt-1 block w-full rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2.5 text-sm text-slate-800 shadow-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none', 'id': 'annonce_description'}}) }}
                <p class="text-xs text-slate-400">Tapez une phrase courte (ex: "j'ai besoin de sang pour un enfant") puis cliquez sur "Améliorer avec l'IA" pour générer une description professionnelle.</p>
                {{ form_errors(form.description) }}
            </div>

            <div class="space-y-1.5">
                {{ form_label(form.datePublication, 'Date de publication', {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(form.datePublication, {
                    'attr': {
                        'class': 'mt-1 block w-full rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2.5 text-sm text-slate-800 shadow-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none',
                        'min': 'now'|date('Y-m-d')
                    }
                }) }}
                {{ form_errors(form.datePublication) }}
            </div>

            <div class="space-y-1.5">
                {{ form_label(form.urgence, 'Niveau d\'urgence', {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(form.urgence, {'attr': {'class': 'mt-1 block w-full rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2.5 text-sm text-slate-800 shadow-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none'}}) }}
                {{ form_errors(form.urgence) }}
            </div>

            <div class="space-y-1.5">
                {{ form_label(form.etatAnnonce, 'État de l\'annonce', {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(form.etatAnnonce, {'attr': {'class': 'mt-1 block w-full rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2.5 text-sm text-slate-800 shadow-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none'}}) }}
                {{ form_errors(form.etatAnnonce) }}
            </div>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-slate-100">
            <a href="{{ path('app_annonce_index') }}" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-700">
                <i class="fa-solid fa-arrow-left"></i>
                Retour à la liste
            </a>
            <button class="inline-flex items-center gap-2 rounded-xl bg-orange-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-orange-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2">
                <i class="fa-solid fa-paper-plane"></i>
                {{ button_label|default('Enregistrer') }}
            </button>
        </div>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}

<script>
(function() {
    const btn = document.getElementById('ai-enhance-btn');
    const textarea = document.getElementById('annonce_description');
    if (!btn || !textarea) return;

    btn.addEventListener('click', async () => {
        const text = (textarea.value || '').trim();
        if (!text) {
            alert('Veuillez d\'abord taper une courte description de votre besoin.');
            return;
        }

        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Génération...';

        try {
            const res = await fetch('{{ path('api_ai_enhance_description') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ text })
            });
            const data = await res.json();

            if (res.ok && data.description) {
                textarea.value = data.description;
            } else {
                alert(data.error || 'Une erreur est survenue. Vérifiez qu\'Ollama tourne (ollama run llama3.2) ou ajoutez GROQ_API_KEY dans .env.');
            }
        } catch (e) {
            alert('Impossible de contacter le service. Assurez-vous qu\'Ollama est lancé ou que GROQ_API_KEY est configuré.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    });
})();
</script>
