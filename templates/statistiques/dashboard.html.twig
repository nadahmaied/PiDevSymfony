{% extends 'base.html.twig' %}

{% block title %}Statistiques des annonces{% endblock %}

{% block body %}
    <h1 class="mb-4">Statistiques des annonces par urgence</h1>

    <div class="row">
        <div class="col-md-5 d-flex justify-content-center mb-4 mb-md-0">
            <div style="max-width: 320px;">
                <canvas id="annoncesUrgenceChart"></canvas>
            </div>
        </div>

        <div class="col-md-7">
            <table class="table table-striped table-sm align-middle">
                <thead>
                <tr>
                    <th>Urgence</th>
                    <th>Nombre d'annonces</th>
                    <th>Pourcentage</th>
                </tr>
                </thead>
                <tbody>
                {% for item in annoncesParUrgence %}
                    <tr>
                        <td>{{ item.urgence|capitalize }}</td>
                        <td>{{ item.total }}</td>
                        <td>
                            {% if annoncesTotal > 0 %}
                                {{ ((item.total / annoncesTotal) * 100)|number_format(1, '.', ' ') }} %
                            {% else %}
                                —
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center">Aucune annonce trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('annoncesUrgenceChart');

        if (ctx) {
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: {{ annoncesParUrgenceLabels|json_encode|raw }},
                    datasets: [{
                        data: {{ annoncesParUrgenceData|json_encode|raw }},
                        backgroundColor: [
                            '#4caf50',
                            '#ff9800',
                            '#f44336'
                        ],
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        },
                        title: {
                            display: true,
                            text: 'Répartition des annonces par niveau d\'urgence'
                        }
                    }
                }
            });
        }
    </script>
{% endblock %}

