{% extends 'baseBack.html.twig' %}

{% block title %}
    <div>
        <h1 class="text-xl font-bold text-gray-800">Modifier l'utilisateur</h1>
        <p class="text-xs text-gray-500 mt-1">Mettez à jour les informations du compte.</p>
    </div>
{% endblock %}

{% block body %}
    <div class="p-6">
        <div class="max-w-xl bg-white rounded-2xl shadow-sm p-6">
            {{ form_start(profileForm, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <div class="space-y-4">
                <div>
                    {{ form_label(profileForm.profilePictureFile, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.profilePictureFile, {'attr': {'class': 'w-full text-sm'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(profileForm.profilePictureFile) }}
                    </div>
                    {% if user.profilePicture %}
                        <div class="mt-2">
                            <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" alt="Photo de profil" class="w-20 h-20 rounded-full object-cover">
                        </div>
                    {% endif %}
                </div>

                <div>
                    {{ form_label(profileForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.email, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(profileForm.email) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        {{ form_label(profileForm.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(profileForm.nom, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                        <div class="text-xs text-red-500">
                            {{ form_errors(profileForm.nom) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(profileForm.prenom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(profileForm.prenom, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                        <div class="text-xs text-red-500">
                            {{ form_errors(profileForm.prenom) }}
                        </div>
                    </div>
                </div>

                <div>
                    {{ form_label(profileForm.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.adresse, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(profileForm.adresse) }}
                    </div>
                </div>

                <div>
                    {{ form_label(profileForm.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.telephone, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(profileForm.telephone) }}
                    </div>
                </div>

                <div>
                    {{ form_label(profileForm.role, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(profileForm.role, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(profileForm.role) }}
                    </div>
                </div>
            </div>

            <div class="mt-6 flex items-center justify-between">
                <a href="{{ path('admin_user_index') }}" class="text-sm text-gray-500 hover:underline">
                    Annuler
                </a>
                <button type="submit"
                        class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    Enregistrer les modifications
                </button>
            </div>

            {{ form_end(profileForm) }}
        </div>
    </div>
{% endblock %}

