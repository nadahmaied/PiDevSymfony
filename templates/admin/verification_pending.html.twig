{% extends 'baseBack.html.twig' %}

{% block title %}
    <div>
        <h1 class="text-xl font-bold text-gray-800">Vérifications en attente</h1>
        <p class="text-xs text-gray-500 mt-1">Examinez et approuvez les documents des médecins.</p>
    </div>
{% endblock %}

{% block body %}
    <div class="p-6 space-y-4">
        {% for message in app.flashes('success') %}
            <div class="rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 text-sm flex items-start gap-2">
                <i class="fa-solid fa-circle-check mt-0.5"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% if pendingUsers is empty %}
            <div class="bg-white rounded-2xl shadow-sm p-8 text-center">
                <i class="fa-solid fa-check-circle text-5xl text-green-500 mb-4"></i>
                <h3 class="text-lg font-semibold text-gray-800">Aucune vérification en attente</h3>
                <p class="text-sm text-gray-500 mt-2">Tous les médecins ont été vérifiés.</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-4">
                {% for user in pendingUsers %}
                    <div class="bg-white rounded-2xl shadow-sm p-6">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-gray-800">
                                    Dr. {{ user.prenom }} {{ user.nom }}
                                </h3>
                                <p class="text-sm text-gray-500">{{ user.email }}</p>
                                <div class="mt-2 flex items-center gap-2">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                        <i class="fa-solid fa-clock mr-1"></i>
                                        En attente de vérification
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <div>
                                <h4 class="text-sm font-medium text-gray-700 mb-2">Diplôme médical</h4>
                                {% if user.diplomaDocument %}
                                    <a href="{{ asset('uploads/documents/' ~ user.diplomaDocument) }}" target="_blank" 
                                       class="block border-2 border-dashed border-gray-300 rounded-lg p-4 hover:border-blue-500 transition text-center">
                                        <i class="fa-solid fa-file-image text-4xl text-gray-400"></i>
                                        <p class="text-xs text-gray-600 mt-2">Cliquez pour voir le diplôme</p>
                                    </a>
                                {% else %}
                                    <p class="text-sm text-gray-500">Non fourni</p>
                                {% endif %}
                            </div>
                        </div>

                        <div class="mt-4 flex items-center gap-2">
                            <form method="post" action="{{ path('admin_verification_approve', { id: user.id }) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve_verification_' ~ user.id) }}">
                                <button type="submit" 
                                        class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium text-white bg-green-600 hover:bg-green-700">
                                    <i class="fa-solid fa-check mr-2"></i>
                                    Approuver
                                </button>
                            </form>

                            <form method="post" action="{{ path('admin_verification_reject', { id: user.id }) }}" 
                                  onsubmit="return confirm('Rejeter cette vérification ?');" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('reject_verification_' ~ user.id) }}">
                                <button type="submit" 
                                        class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium text-white bg-red-600 hover:bg-red-700">
                                    <i class="fa-solid fa-times mr-2"></i>
                                    Rejeter
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
