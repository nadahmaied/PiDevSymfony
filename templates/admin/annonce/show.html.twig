{% extends 'admin_base.html.twig' %}

{% block title %}Admin - Détail annonce #{{ annonce.id }}{% endblock %}

{% block page_header %}Détail de l'annonce{% endblock %}
{% block page_subtitle %}Visualisation et gestion de l'annonce sélectionnée{% endblock %}

{% block header_actions %}
    <div class="flex gap-2">
        <a href="{{ path('admin_annonce_index') }}" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
            <i class="fa-solid fa-arrow-left"></i>
            Retour à la liste
        </a>
        <a href="{{ path('admin_donation_new_for_annonce', {'annonce': annonce.id}) }}" class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700">
            <i class="fa-solid fa-hand-holding-heart"></i>
            Accepter
        </a>
        <a href="{{ path('admin_annonce_edit', {'id': annonce.id}) }}" class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700">
            <i class="fa-solid fa-pen"></i>
            Modifier
        </a>
    </div>
{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 p-6 space-y-4">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h1 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                        <i class="fa-solid fa-bullhorn text-orange-500"></i>
                        {{ annonce.titreAnnonce }}
                    </h1>
                    <p class="text-xs text-slate-400 mt-1">
                        Publié le {{ annonce.datePublication ? annonce.datePublication|date('d M Y') : '—' }}
                    </p>
                </div>
                {% set badgeColor =
                    annonce.urgence == 'élevée' ? 'bg-red-100 text-red-700' :
                    (annonce.urgence == 'moyenne' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700')
                %}
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold {{ badgeColor }}">
                    <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                    {{ annonce.urgence|capitalize }}
                </span>
            </div>

            <div class="pt-4 border-t border-slate-100">
                <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide mb-2">
                    Description du besoin
                </h2>
                <p class="text-sm text-slate-700 whitespace-pre-line">
                    {{ annonce.description }}
                </p>
            </div>

            <div class="pt-4 border-t border-slate-100">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide flex items-center gap-2">
                        <i class="fa-solid fa-hand-holding-heart text-emerald-500"></i>
                        Donations associées
                    </h2>
                    <span class="text-xs text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full">
                        {{ annonce.donations|length }} donation{{ annonce.donations|length > 1 ? 's' : '' }}
                    </span>
                </div>
                
                {% if annonce.donations|length > 0 %}
                    <div class="space-y-3">
                        {% for donation in annonce.donations %}
                            <div class="border border-slate-200 rounded-xl p-4 hover:bg-slate-50 transition-colors">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-2">
                                            <h3 class="font-semibold text-slate-800 text-sm">{{ donation.typeDon }}</h3>
                                            {% set statutColor = 
                                                donation.statut == 'accepté' ? 'bg-emerald-100 text-emerald-700' :
                                                (donation.statut == 'refusé' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700')
                                            %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium {{ statutColor }}">
                                                {{ donation.statut|capitalize }}
                                            </span>
                                        </div>
                                        <div class="grid grid-cols-2 gap-3 text-xs text-slate-600">
                                            <div>
                                                <span class="text-slate-500">Quantité:</span>
                                                <span class="font-medium text-slate-700 ml-1">{{ donation.quantite }}</span>
                                            </div>
                                            <div>
                                                <span class="text-slate-500">Date:</span>
                                                <span class="font-medium text-slate-700 ml-1">{{ donation.dateDonation ? donation.dateDonation|date('d M Y') : '—' }}</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex gap-2">
                                        <a href="{{ path('admin_donation_show', {'id': donation.id}) }}" class="inline-flex items-center gap-1 text-xs text-blue-600 hover:text-blue-700 font-medium">
                                            Voir <i class="fa-solid fa-arrow-right"></i>
                                        </a>
                                        <a href="{{ path('admin_donation_edit', {'id': donation.id}) }}" class="inline-flex items-center gap-1 text-xs text-orange-600 hover:text-orange-700 font-medium">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-8 text-slate-400">
                        <i class="fa-solid fa-inbox text-3xl mb-2"></i>
                        <p class="text-sm">Aucune donation associée à cette annonce pour le moment.</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="space-y-4">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 space-y-4">
                <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide">
                    Informations
                </h2>
                <div class="space-y-3 text-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">Identifiant</span>
                        <span class="font-mono text-slate-800">#{{ annonce.id }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">Urgence</span>
                        {% set badgeColorSmall =
                            annonce.urgence == 'élevée' ? 'bg-red-100 text-red-700' :
                            (annonce.urgence == 'moyenne' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700')
                        %}
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold {{ badgeColorSmall }}">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                            {{ annonce.urgence|capitalize }}
                        </span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-slate-500">État</span>
                        <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full
                            {% if annonce.etatAnnonce == 'active' %}
                                bg-emerald-50 text-emerald-700
                            {% else %}
                                bg-slate-100 text-slate-600
                            {% endif %}
                        ">
                            <i class="fa-solid {{ annonce.etatAnnonce == 'active' ? 'fa-circle-check' : 'fa-circle-xmark' }}"></i>
                            {{ annonce.etatAnnonce == 'active' ? 'Active' : 'Clôturée' }}
                        </span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-red-100 p-6 space-y-3">
                <h2 class="text-sm font-semibold text-red-700 uppercase tracking-wide flex items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    Suppression
                </h2>
                <p class="text-xs text-slate-500">Cette action est irréversible. L'annonce sera définitivement supprimée de la plateforme.</p>
                {{ include('admin/annonce/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}

