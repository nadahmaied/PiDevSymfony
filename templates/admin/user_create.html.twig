{% extends 'baseBack.html.twig' %}

{% block title %}
    <div>
        <h1 class="text-xl font-bold text-gray-800">Créer un utilisateur</h1>
        <p class="text-xs text-gray-500 mt-1">Ajoutez un nouveau compte utilisateur.</p>
    </div>
{% endblock %}

{% block body %}
    <div class="p-6">
        <div class="max-w-xl bg-white rounded-2xl shadow-sm p-6">
            {{ form_start(registrationForm) }}

            <div class="space-y-4">
                <div>
                    {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(registrationForm.email) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        {{ form_label(registrationForm.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(registrationForm.nom, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                        <div class="text-xs text-red-500">
                            {{ form_errors(registrationForm.nom) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(registrationForm.prenom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(registrationForm.prenom, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                        <div class="text-xs text-red-500">
                            {{ form_errors(registrationForm.prenom) }}
                        </div>
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.adresse, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(registrationForm.adresse) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.telephone, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(registrationForm.telephone) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.plainPassword, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.role, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.role, {'attr': {'class': 'w-full rounded-lg border-gray-300 focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2'}}) }}
                    <div class="text-xs text-red-500">
                        {{ form_errors(registrationForm.role) }}
                    </div>
                </div>
            </div>

            <div class="mt-6 flex items-center justify-between">
                <a href="{{ path('admin_user_index') }}" class="text-sm text-gray-500 hover:underline">
                    Annuler
                </a>
                <button type="submit"
                        class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    Créer l'utilisateur
                </button>
            </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}
